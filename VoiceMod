	local fillGlow = Instance.new("Frame")
	fillGlow.Size = UDim2.new(1, 0, 3, 0)
	fillGlow.Position = UDim2.new(0, 0, -1, 0)
	fillGlow.BackgroundColor3 = cfg.color
	fillGlow.BackgroundTransparency = 0.8
	fillGlow.BorderSizePixel = 0
	fillGlow.Parent = fill
	
	local knobSize = math.floor(isMobile and 22 or 18)
	local hitboxSize = math.floor(isMobile and 44 or 30)
	
	local knobHitbox = Instance.new("TextButton")
	knobHitbox.Name = "KnobHitbox"
	knobHitbox.Size = UDim2.new(0, hitboxSize, 0, hitboxSize)
	knobHitbox.Position = UDim2.new(initFill, -hitboxSize/2, 0.5, -hitboxSize/2)
	knobHitbox.BackgroundTransparency = 1
	knobHitbox.Text = ""
	knobHitbox.ZIndex = 6
	knobHitbox.Parent = track
	
	local knob = Instance.new("Frame")
	knob.Name = "Knob"
	knob.Size = UDim2.new(0, knobSize, 0, knobSize)
	knob.Position = UDim2.new(0.5, -knobSize/2, 0.5, -knobSize/2)
	knob.BackgroundColor3 = C.white
	knob.ZIndex = 7
	knob.Parent = knobHitbox
	corner(knob, knobSize/2)
	stroke(knob, cfg.color, 2, 0)
	
	local knobInner = Instance.new("Frame")
	knobInner.Size = UDim2.new(0, math.floor(knobSize * 0.4), 0, math.floor(knobSize * 0.4))
	knobInner.Position = UDim2.new(0.5, -math.floor(knobSize * 0.2), 0.5, -math.floor(knobSize * 0.2))
	knobInner.BackgroundColor3 = cfg.color
	knobInner.ZIndex = 8
	knobInner.Parent = knob
	corner(knobInner, knobSize)
	
	local dragging = false
	
	local function applySlider(inputX)
		local absPos = track.AbsolutePosition.X
		local absSize = track.AbsoluteSize.X
		local rel = math.clamp((inputX - absPos) / absSize, 0, 1)
		local value = cfg.min + rel * (cfg.max - cfg.min)
		value = math.floor(value * 100 + 0.5) / 100
		
		state[cfg.key] = value
		fill.Size = UDim2.new(rel, 0, 1, 0)
		knobHitbox.Position = UDim2.new(rel, -hitboxSize/2, 0.5, -hitboxSize/2)
		val.Text = string.format("%.2f", value)
		
		state.activePreset = nil
		for _, pb in pairs(presetBtns) do
			tw(pb.btn, {BackgroundColor3 = C.card}, 0.15)
			tw(pb.glow, {BackgroundTransparency = 1}, 0.15)
			tw(pb.stroke, {Color = C.border, Transparency = 0.55}, 0.15)
			tw(pb.dot, {BackgroundTransparency = 1}, 0.15)
		end
		
		syncEffects()
		replicate()
	end
	
	knobHitbox.InputBegan:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
			dragging = true
			contentScroll.ScrollingEnabled = false
			tw(knob, {Size = UDim2.new(0, knobSize + 6, 0, knobSize + 6), Position = UDim2.new(0.5, -(knobSize+6)/2, 0.5, -(knobSize+6)/2)}, 0.12)
			applySlider(input.Position.X)
		end
	end)
	
	track.InputBegan:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
			dragging = true
			contentScroll.ScrollingEnabled = false
			tw(knob, {Size = UDim2.new(0, knobSize + 6, 0, knobSize + 6), Position = UDim2.new(0.5, -(knobSize+6)/2, 0.5, -(knobSize+6)/2)}, 0.12)
			applySlider(input.Position.X)
		end
	end)
	
	UserInputService.InputChanged:Connect(function(input)
		if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
			applySlider(input.Position.X)
		end
	end)
	
	UserInputService.InputEnded:Connect(function(input)
		if dragging and (input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch) then
			dragging = false
			contentScroll.ScrollingEnabled = true
			tw(knob, {Size = UDim2.new(0, knobSize, 0, knobSize), Position = UDim2.new(0.5, -knobSize/2, 0.5, -knobSize/2)}, 0.2)
		end
	end)
	
	sliderRefs[cfg.key] = {fill = fill, knob = knobHitbox, val = val, track = track, cfg = cfg, knobFrame = knob, hitboxSize = hitboxSize}
end

