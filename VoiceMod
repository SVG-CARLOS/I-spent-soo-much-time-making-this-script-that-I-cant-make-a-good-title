local function corner(parent, r)
	local c = Instance.new("UICorner")
	c.CornerRadius = UDim.new(0, r or 8)
	c.Parent = parent
	return c
end

local function stroke(parent, color, thick, trans)
	local s = Instance.new("UIStroke")
	s.Color = color or C.border
	s.Thickness = thick or 1
	s.Transparency = trans or 0.5
	s.ApplyStrokeMode = Enum.ApplyStrokeMode.Border
	s.Parent = parent
	return s
end

local function grad(parent, c1, c2, rot)
	local g = Instance.new("UIGradient")
	g.Color = ColorSequence.new(c1, c2)
	g.Rotation = rot or 90
	g.Parent = parent
	return g
end

local function pad(parent, t, b, l, r)
	local p = Instance.new("UIPadding")
	p.PaddingTop = UDim.new(0, t or 0)
	p.PaddingBottom = UDim.new(0, b or 0)
	p.PaddingLeft = UDim.new(0, l or 0)
	p.PaddingRight = UDim.new(0, r or 0)
	p.Parent = parent
	return p
end

local function lerp(a, b, t)
	return a + (b - a) * math.clamp(t, 0, 1)
end

local function lerpC(a, b, t)
	t = math.clamp(t, 0, 1)
	return Color3.new(lerp(a.R, b.R, t), lerp(a.G, b.G, t), lerp(a.B, b.B, t))
end

local function tw(obj, props, dur, style, dir)
	local t = TweenService:Create(obj, TweenInfo.new(dur or 0.25, style or Enum.EasingStyle.Quint, dir or Enum.EasingDirection.Out), props)
	t:Play()
	return t
end

local function spring(obj, props, dur)
	return tw(obj, props, dur or 0.45, Enum.EasingStyle.Back, Enum.EasingDirection.Out)
end

local function getAudioAnalyzer()
	local character = player.Character
	if not character then return nil end
	local head = character:FindFirstChild("Head")
	if not head then return nil end
	
	local analyzer = head:FindFirstChild("VoiceAnalyzer")
	if not analyzer then
		pcall(function()
			analyzer = Instance.new("AudioAnalyzer")
			analyzer.Name = "VoiceAnalyzer"
			analyzer.Parent = head
			
			local listener = head:FindFirstChildOfClass("AudioListener") or head:FindFirstChild("AudioListener")
			if not listener then
				for _, desc in pairs(head:GetDescendants()) do
					if desc:IsA("AudioListener") then
						listener = desc
						break
					end
				end
			end
			
			if listener then
				local wire = Instance.new("Wire")
				wire.SourceInstance = listener
				wire.TargetInstance = analyzer
				wire.Parent = head
			end
		end)
	end
	return analyzer
end

local function getRealLoudness()
	local analyzer = getAudioAnalyzer()
	if analyzer then
		local success, spectrum = pcall(function()
			return analyzer:GetSpectrum()
		end)
		if success and spectrum then
			local total = 0
			local count = 0
			for i, v in ipairs(spectrum) do
				total = total + math.abs(v)
				count = count + 1
			end
			if count > 0 then
				return math.clamp(total / count * 500, 0, 1), spectrum
			end
		end
		
		local success2, peak = pcall(function()
			return analyzer:GetPeakLevel()
		end)
		if success2 and peak then
			return math.clamp(math.max(peak.X or 0, peak.Y or 0), 0, 1), nil
		end
	end
	
	local character = player.Character
	if character then
		local head = character:FindFirstChild("Head")
		if head then
			for _, child in pairs(head:GetChildren()) do
				if child:IsA("Sound") and child.Playing then
					local loud = child.PlaybackLoudness / 1000
					return math.clamp(loud, 0, 1), nil
				end
			end
		end
	end
	
	return 0, nil
end

local function processAudioData(dt)
	local rawLoudness, spectrum = getRealLoudness()
	
	state.smoothLoudness = lerp(state.smoothLoudness, rawLoudness, math.clamp(dt * 12, 0, 1))
	state.loudness = state.smoothLoudness
	
	local bandCount = 48
	
	if spectrum and #spectrum > 0 then
		local specLen = #spectrum
		for i = 1, bandCount do
			local startIdx = math.floor((i - 1) / bandCount * specLen) + 1
			local endIdx = math.floor(i / bandCount * specLen)
			endIdx = math.max(endIdx, startIdx)
			
			local bandVal = 0
			local count = 0
			for j = startIdx, math.min(endIdx, specLen) do
				bandVal = bandVal + math.abs(spectrum[j])
				count = count + 1
			end
			if count > 0 then
				bandVal = bandVal / count
			end
			
			local logScale = 1 + math.log(i) / math.log(bandCount) * 2
			bandVal = bandVal * logScale * 300
			
			bandVal = bandVal * (0.5 + state.pitch * 0.3 + state.distortion * 0.4)
			
			bandVal = math.clamp(bandVal, 0, 1)
			
			local smoothing = math.clamp(dt * 15, 0, 1)
			state.frequencyBands[i] = lerp(state.frequencyBands[i], bandVal, smoothing)
			
			if state.frequencyBands[i] > state.peakHold[i] then
				state.peakHold[i] = state.frequencyBands[i]
			else
				state.peakHold[i] = math.max(0, state.peakHold[i] - dt * 0.8)
			end
			
			table.insert(state.analyzerHistory[i], 1, state.frequencyBands[i])
			if #state.analyzerHistory[i] > 8 then
				table.remove(state.analyzerHistory[i])
			end
		end
	else
		for i = 1, bandCount do
			local falloff = math.max(0, state.frequencyBands[i] - dt * 3)
			state.frequencyBands[i] = falloff
			state.peakHold[i] = math.max(0, state.peakHold[i] - dt * 0.5)
		end
	end
end

local function setupEffects()
	local character = player.Character or player.CharacterAdded:Wait()
	local head = character:WaitForChild("Head", 10)
	if not head then return end
	
	local effectNames = {"VMPitch", "VMReverb", "VMDistortion", "VMChorus", "VMEcho", "VMFlanger", "VMCompressor", "VMTremolo", "VMEqualizer"}
	for _, name in ipairs(effectNames) do
		local existing = head:FindFirstChild(name)
		if existing then existing:Destroy() end
	end
	
	local pitch = Instance.new("PitchShiftSoundEffect")
	pitch.Name = "VMPitch"
	pitch.Octave = state.pitch
	pitch.Enabled = state.enabled
	pitch.Parent = head
	
	local eq = Instance.new("EqualizerSoundEffect")
	eq.Name = "VMEqualizer"
	eq.HighGain = 0
	eq.MidGain = 0
	eq.LowGain = 0
	eq.Enabled = state.enabled
	eq.Parent = head
	
	local reverb = Instance.new("ReverbSoundEffect")
	reverb.Name = "VMReverb"
	reverb.DecayTime = math.max(0.1, state.reverb * 12)
	reverb.Density = state.reverb
	reverb.Diffusion = state.reverb
	reverb.DryLevel = 0
	reverb.WetLevel = state.reverb > 0.01 and (state.reverb * -15 + (-15)) or -80
	reverb.Enabled = state.enabled and state.reverb > 0.01
	reverb.Parent = head
	
	local dist = Instance.new("DistortionSoundEffect")
	dist.Name = "VMDistortion"
	dist.Level = state.distortion * 0.75
	dist.Enabled = state.enabled and state.distortion > 0.01
	dist.Parent = head
	
	local chor = Instance.new("ChorusSoundEffect")
	chor.Name = "VMChorus"
	chor.Depth = state.chorus * 0.8
	chor.Mix = state.chorus * 0.7
	chor.Rate = math.max(0.01, state.chorus * 4)
	chor.Enabled = state.enabled and state.chorus > 0.01
	chor.Parent = head
	
	local ech = Instance.new("EchoSoundEffect")
	ech.Name = "VMEcho"
	ech.Delay = math.max(0.02, state.echo * 0.4 + 0.02)
	ech.Feedback = state.echo * 0.55
	ech.DryMix = 1
	ech.WetMix = state.echo * 0.8
	ech.Enabled = state.enabled and state.echo > 0.01
	ech.Parent = head
	
	local fla = Instance.new("FlangeSoundEffect")
	fla.Name = "VMFlanger"
	fla.Depth = state.flanger * 0.9
	fla.Mix = state.flanger * 0.75
	fla.Rate = math.max(0.01, state.flanger * 8)
	fla.Enabled = state.enabled and state.flanger > 0.01
	fla.Parent = head
	
	local comp = Instance.new("CompressorSoundEffect")
	comp.Name = "VMCompressor"
	comp.Threshold = -8 - state.compressor * 32
	comp.Attack = 0.005
	comp.Release = 0.08
	comp.Ratio = 1 + state.compressor * 24
	comp.GainMakeup = state.compressor * 10
	comp.Enabled = state.enabled and state.compressor > 0.01
	comp.Parent = head
	
	local trem = Instance.new("TremoloSoundEffect")
	trem.Name = "VMTremolo"
	trem.Depth = state.tremolo * 0.85
	trem.Frequency = math.max(0.01, state.tremolo * 12)
	trem.Duty = 0.5
	trem.Enabled = state.enabled and state.tremolo > 0.01
	trem.Parent = head
end

local function syncEffects()
	local character = player.Character
	if not character then return end
	local head = character:FindFirstChild("Head")
	if not head then return end
	
	local p = head:FindFirstChild("VMPitch")
	if p then p.Octave = state.pitch; p.Enabled = state.enabled end
	
	local r = head:FindFirstChild("VMReverb")
	if r then
		r.DecayTime = math.max(0.1, state.reverb * 12)
		r.Density = state.reverb
		r.Diffusion = state.reverb
		r.WetLevel = state.reverb > 0.01 and (state.reverb * -15 + (-15)) or -80
		r.Enabled = state.enabled and state.reverb > 0.01
	end
	
	local d = head:FindFirstChild("VMDistortion")
	if d then d.Level = state.distortion * 0.75; d.Enabled = state.enabled and state.distortion > 0.01 end
	
	local ch = head:FindFirstChild("VMChorus")
	if ch then
		ch.Depth = state.chorus * 0.8
		ch.Mix = state.chorus * 0.7
		ch.Rate = math.max(0.01, state.chorus * 4)
		ch.Enabled = state.enabled and state.chorus > 0.01
	end
	
	local ec = head:FindFirstChild("VMEcho")
	if ec then
		ec.Delay = math.max(0.02, state.echo * 0.4 + 0.02)
		ec.Feedback = state.echo * 0.55
		ec.WetMix = state.echo * 0.8
		ec.Enabled = state.enabled and state.echo > 0.01
	end
	
	local fl = head:FindFirstChild("VMFlanger")
	if fl then
		fl.Depth = state.flanger * 0.9
		fl.Mix = state.flanger * 0.75
		fl.Rate = math.max(0.01, state.flanger * 8)
		fl.Enabled = state.enabled and state.flanger > 0.01
	end
	
	local co = head:FindFirstChild("VMCompressor")
	if co then
		co.Threshold = -8 - state.compressor * 32
		co.Ratio = 1 + state.compressor * 24
		co.GainMakeup = state.compressor * 10
		co.Enabled = state.enabled and state.compressor > 0.01
	end
	
	local tr = head:FindFirstChild("VMTremolo")
	if tr then
		tr.Depth = state.tremolo * 0.85
		tr.Frequency = math.max(0.01, state.tremolo * 12)
		tr.Enabled = state.enabled and state.tremolo > 0.01
	end
	
	local eq = head:FindFirstChild("VMEqualizer")
	if eq then
		if state.pitch < 0.8 then
			eq.LowGain = (1 - state.pitch) * 6
			eq.MidGain = 0
			eq.HighGain = -(1 - state.pitch) * 3
		elseif state.pitch > 1.3 then
			eq.LowGain = -(state.pitch - 1) * 4
			eq.MidGain = (state.pitch - 1) * 2
			eq.HighGain = (state.pitch - 1) * 5
		else
			eq.LowGain = 0
			eq.MidGain = 0
			eq.HighGain = 0
		end
		eq.Enabled = state.enabled
	end
end

local function replicate()
	local character = player.Character
	if not character then return end
	local head = character:FindFirstChild("Head")
	if not head then return end
	
	local cfg = head:FindFirstChild("VMConfig")
	if not cfg then
		cfg = Instance.new("StringValue")
		cfg.Name = "VMConfig"
		cfg.Parent = head
	end
	
	cfg.Value = string.format("%.3f|%.3f|%.3f|%.3f|%.3f|%.3f|%.3f|%.3f|%s",
		state.pitch, state.reverb, state.distortion, state.chorus,
		state.echo, state.flanger, state.compressor, state.tremolo,
		tostring(state.enabled))
end

