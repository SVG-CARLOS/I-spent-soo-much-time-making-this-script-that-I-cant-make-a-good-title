local function refreshSliderVisuals()
	for key, ref in pairs(sliderRefs) do
		local cfg = ref.cfg
		local rel = math.clamp((state[key] - cfg.min) / (cfg.max - cfg.min), 0, 1)
		tw(ref.fill, {Size = UDim2.new(rel, 0, 1, 0)}, 0.3)
		tw(ref.knob, {Position = UDim2.new(rel, -ref.hitboxSize/2, 0.5, -ref.hitboxSize/2)}, 0.3)
		ref.val.Text = string.format("%.2f", state[key])
	end
end

