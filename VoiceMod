local function applyOtherPlayerEffects(otherPlayer)
	task.spawn(function()
		while otherPlayer.Parent do
			local char = otherPlayer.Character
			if char then
				local head = char:FindFirstChild("Head")
				if head then
					local cfg = head:FindFirstChild("VMConfig")
					if cfg and cfg:IsA("StringValue") and cfg.Value ~= "" then
						local parts = string.split(cfg.Value, "|")
						if #parts >= 9 then
							local vals = {}
							for i = 1, 8 do vals[i] = tonumber(parts[i]) or 0 end
							local enabled = parts[9] == "true"
							
							local function getOrCreate(class, name)
								local existing = head:FindFirstChild(name)
								if not existing then
									existing = Instance.new(class)
									existing.Name = name
									existing.Parent = head
								end
								return existing
							end
							
							local p = getOrCreate("PitchShiftSoundEffect", "VMPitch")
							p.Octave = vals[1]
							p.Enabled = enabled
							
							local r = getOrCreate("ReverbSoundEffect", "VMReverb")
							r.DecayTime = math.max(0.1, vals[2] * 12)
							r.Density = vals[2]
							r.Diffusion = vals[2]
							r.WetLevel = vals[2] > 0.01 and (vals[2] * -15 + (-15)) or -80
							r.Enabled = enabled and vals[2] > 0.01
							
							local d = getOrCreate("DistortionSoundEffect", "VMDistortion")
							d.Level = vals[3] * 0.75
							d.Enabled = enabled and vals[3] > 0.01
							
							local ch = getOrCreate("ChorusSoundEffect", "VMChorus")
							ch.Depth = vals[4] * 0.8
							ch.Mix = vals[4] * 0.7
							ch.Rate = math.max(0.01, vals[4] * 4)
							ch.Enabled = enabled and vals[4] > 0.01
							
							local ec = getOrCreate("EchoSoundEffect", "VMEcho")
							ec.Delay = math.max(0.02, vals[5] * 0.4 + 0.02)
							ec.Feedback = vals[5] * 0.55
							ec.WetMix = vals[5] * 0.8
							ec.Enabled = enabled and vals[5] > 0.01
							
							local fl = getOrCreate("FlangeSoundEffect", "VMFlanger")
							fl.Depth = vals[6] * 0.9
							fl.Mix = vals[6] * 0.75
							fl.Rate = math.max(0.01, vals[6] * 8)
							fl.Enabled = enabled and vals[6] > 0.01
							
							local co = getOrCreate("CompressorSoundEffect", "VMCompressor")
							co.Threshold = -8 - vals[7] * 32
							co.Ratio = 1 + vals[7] * 24
							co.Enabled = enabled and vals[7] > 0.01
							
							local tr = getOrCreate("TremoloSoundEffect", "VMTremolo")
							tr.Depth = vals[8] * 0.85
							tr.Frequency = math.max(0.01, vals[8] * 12)
							tr.Enabled = enabled and vals[8] > 0.01
							
							local eq = getOrCreate("EqualizerSoundEffect", "VMEqualizer")
							if vals[1] < 0.8 then
								eq.LowGain = (1 - vals[1]) * 6
								eq.HighGain = -(1 - vals[1]) * 3
							elseif vals[1] > 1.3 then
								eq.LowGain = -(vals[1] - 1) * 4
								eq.HighGain = (vals[1] - 1) * 5
							else
								eq.LowGain = 0
								eq.HighGain = 0
							end
							eq.Enabled = enabled
						end
					end
				end
			end
			task.wait(0.8)
		end
	end)
end

