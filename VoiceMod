task.spawn(function()
	local clock = 0
	while true do
		local dt = RunService.RenderStepped:Wait()
		clock = clock + dt
		
		processAudioData(dt)
		
		local maxBarH = analyzerH - 10
		for i = 1, barCount do
			local bandVal = state.frequencyBands[i]
			local peakVal = state.peakHold[i]
			
			local h = math.max(2, bandVal * maxBarH)
			local peakH = math.max(2, peakVal * maxBarH)
			
			bars[i].Size = UDim2.new(0, barWidth, 0, h)
			bars[i].Position = UDim2.new(0, bars[i].Position.X.Offset, 1, -4)
			
			local t = math.clamp(i / barCount, 0, 1)
			local barColor
			if bandVal > 0.7 then
				barColor = lerpC(C.gold, C.red, (bandVal - 0.7) / 0.3)
			elseif bandVal > 0.4 then
				barColor = lerpC(C.cyan, C.gold, (bandVal - 0.4) / 0.3)
			else
				barColor = lerpC(C.accentDim, C.cyan, t)
			end
			
			if state.distortion > 0.3 then
				barColor = lerpC(barColor, C.red, state.distortion * 0.4)
			end
			
			bars[i].BackgroundColor3 = barColor
			bars[i].BackgroundTransparency = state.enabled and 0.05 or 0.7
			
			peakDots[i].Position = UDim2.new(0, bars[i].Position.X.Offset, 1, -(peakH + 6))
			peakDots[i].BackgroundTransparency = state.enabled and 0.35 or 0.85
			
			reflectionBars[i].Size = UDim2.new(0, barWidth, 0, math.max(1, h * 0.2))
			reflectionBars[i].BackgroundTransparency = 0.88
			reflectionBars[i].BackgroundColor3 = barColor
		end
		
		local dbValue = state.loudness > 0.001 and (20 * math.log10(state.loudness)) or -math.huge
		if dbValue > -100 then
			dbLabel.Text = string.format("%.0f dB", dbValue)
		else
			dbLabel.Text = "-∞ dB"
		end
		
		levelFill.Size = UDim2.new(math.clamp(state.loudness, 0, 1), 0, 1, 0)
		if state.loudness > 0.8 then
			levelFill.BackgroundColor3 = C.red
		elseif state.loudness > 0.5 then
			levelFill.BackgroundColor3 = C.gold
		else
			levelFill.BackgroundColor3 = C.green
		end
		
		scanline.Position = UDim2.new(0, 0, (math.sin(clock * 0.8) + 1) / 2, 0)
		scanline.BackgroundTransparency = 0.88 + math.sin(clock * 3) * 0.05
		
		if state.enabled then
			local pulse = (math.sin(clock * 5) + 1) / 2
			statusDot.BackgroundTransparency = pulse * 0.35
			logoGlow.BackgroundTransparency = 0.7 + pulse * 0.15
		else
			statusDot.BackgroundTransparency = 0
			logoGlow.BackgroundTransparency = 0.9
		end
	end
end)

