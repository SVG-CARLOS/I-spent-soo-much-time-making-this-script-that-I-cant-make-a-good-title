local AccessorySystem = {}

function AccessorySystem:CreateHalo(character)
    local head = character:FindFirstChild("Head")
    if not head then return end
    
    if character:FindFirstChild("MCHalo") then return end
    
    local haloModel = Instance.new("Model")
    haloModel.Name = "MCHalo"
    
    -- Create halo ring using parts
    local segments = 16
    local radius = 1.2
    local thickness = 0.08
    
    for i = 1, segments do
        local angle = (i / segments) * math.pi * 2
        local x = math.cos(angle) * radius
        local z = math.sin(angle) * radius
        
        local part = CreateInstance("Part", {
            Name = "HaloSegment_" .. i,
            Size = Vector3.new(thickness * 3, thickness, thickness * 3),
            Shape = Enum.PartType.Ball,
            Material = Enum.Material.Neon,
            Color = CONFIG.HALO_COLOR,
            CanCollide = false,
            Anchored = false,
            Massless = true,
            CastShadow = false,
        }, haloModel)
        
        local weld = CreateInstance("Weld", {
            Part0 = head,
            Part1 = part,
            C0 = CFrame.new(x, 1.6, z),
        }, part)
    end
    
    -- Center glow
    local glowPart = CreateInstance("Part", {
        Name = "HaloGlow",
        Size = Vector3.new(0.1, 0.1, 0.1),
        Transparency = 1,
        CanCollide = false,
        Anchored = false,
        Massless = true,
    }, haloModel)
    
    CreateInstance("Weld", {
        Part0 = head,
        Part1 = glowPart,
        C0 = CFrame.new(0, 1.6, 0),
    }, glowPart)
    
    local haloLight = CreateInstance("PointLight", {
        Color = CONFIG.HALO_GLOW_COLOR,
        Brightness = 1.5,
        Range = 8,
    }, glowPart)
    
    local haloParticles = CreateInstance("Attachment", {Name = "HaloAtt"}, glowPart)
    CreateInstance("ParticleEmitter", {
        Color = ColorSequence.new(CONFIG.HALO_COLOR),
        Size = NumberSequence.new({
            NumberSequenceKeypoint.new(0, 0),
            NumberSequenceKeypoint.new(0.5, 0.15),
            NumberSequenceKeypoint.new(1, 0),
        }),
        Transparency = NumberSequence.new({
            NumberSequenceKeypoint.new(0, 0.3),
            NumberSequenceKeypoint.new(1, 1),
        }),
        Lifetime = NumberRange.new(0.3, 0.8),
        Rate = 20,
        Speed = NumberRange.new(0.5, 2),
        SpreadAngle = Vector2.new(360, 360),
        LightEmission = 1,
        Brightness = 3,
    }, haloParticles)
    
    haloModel.Parent = character
    State.HaloModel = haloModel
end

