function AccessorySystem:AnimateWings(dt)
    if not State.WingsModel or not State.WingsModel.Parent then return end
    
    local t = tick()
    local flapAngle = math.sin(t * 3) * math.rad(15)
    local breathAngle = math.sin(t * 1.5) * math.rad(5)
    
    for _, part in pairs(State.WingsModel:GetChildren()) do
        if part:IsA("Part") and part.Name:find("Feather") then
            local weld = part:FindFirstChild("FeatherWeld")
            if weld then
                local idx = tonumber(part.Name:match("%d+")) or 1
                local isRight = idx <= 5
                local sign = isRight and 1 or -1
                
                local extraAngle = flapAngle * sign + breathAngle
                -- Apply gentle flap by modifying the weld C1
                weld.C1 = CFrame.Angles(0, 0, extraAngle * 0.5)
            end
        end
    end
end

function AccessorySystem:AnimateHalo(dt)
    if not State.HaloModel or not State.HaloModel.Parent then return end
    
    local t = tick()
    local bobOffset = math.sin(t * 2) * 0.1
    local rotOffset = t * 0.5
    
    for _, part in pairs(State.HaloModel:GetChildren()) do
        if part:IsA("Part") and part.Name:find("HaloSegment") then
            local weld = part:FindFirstChildOfClass("Weld")
            if weld then
                weld.C1 = CFrame.new(0, -bobOffset, 0) * CFrame.Angles(0, rotOffset, 0)
            end
        end
    end
end

function AccessorySystem:Toggle(character)
    State.AccessoriesEnabled = not State.AccessoriesEnabled
    
    if State.AccessoriesEnabled then
        self:CreateHalo(character)
        self:CreateWings(character)
    else
        if State.HaloModel then
            State.HaloModel:Destroy()
            State.HaloModel = nil
        end
        if State.WingsModel then
            State.WingsModel:Destroy()
            State.WingsModel = nil
        end
    end
end

function AccessorySystem:Remove()
    if State.HaloModel then
        pcall(function() State.HaloModel:Destroy() end)
        State.HaloModel = nil
    end
    if State.WingsModel then
        pcall(function() State.WingsModel:Destroy() end)
        State.WingsModel = nil
    end
    State.AccessoriesEnabled = false
end

