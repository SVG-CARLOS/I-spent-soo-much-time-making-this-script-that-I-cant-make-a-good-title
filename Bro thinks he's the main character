------------------------------------------------------------------------
-- MAIN CHARACTER INITIALIZATION
------------------------------------------------------------------------
local footstepEmitter = nil

local function SetupCharacter(character)
    -- Clean previous connections
    for _, conn in pairs(State.Connections) do
        pcall(function() conn:Disconnect() end)
    end
    State.Connections = {}
    
    -- Wait for character to fully load
    local humanoid = character:WaitForChild("Humanoid", 10)
    local rootPart = character:WaitForChild("HumanoidRootPart", 10)
    
    if not humanoid or not rootPart then
        warn("[MC] Character components missing")
        return
    end
    
    -- Detect rig type
    State.RigType = DetectRigType(character)
    if not State.RigType then
        -- Wait a bit and try again
        task.wait(1)
        State.RigType = DetectRigType(character)
        if not State.RigType then
            warn("[MC] Could not detect rig type")
            return
        end
    end
    
    State.Character = character
    State.Humanoid = humanoid
    State.RootPart = rootPart
    State.EntrancePlayed = false
    State.IsFalling = false
    State.IsLevitating = false
    State.IsDodging = false
    lastHealth = humanoid.Health
    
    -- Collect motors
    MotorManager:CollectMotors(character)
    
    -- Create aura
    AuraSystem:CreateAura(character)
    
    -- Create overhead gui
    CreateOverheadGui(character)
    
    -- Footstep particles
    footstepEmitter = CreateFootstepEffect()
    
    -- Re-enable accessories if they were on
    if State.AccessoriesEnabled then
        AccessorySystem:CreateHalo(character)
        AccessorySystem:CreateWings(character)
    end
    
    -- Start idle animation
    AnimPlayer:Play("idle", true)
    
    -- Health monitoring for dodge
    table.insert(State.Connections, humanoid.HealthChanged:Connect(OnHealthChanged))
    
    -- State change monitoring
    table.insert(State.Connections, humanoid.StateChanged:Connect(function(oldState, newState)
        if State.IsLevitating or State.IsDodging then return end
        
        if newState == Enum.HumanoidStateType.Jumping then
            AnimPlayer:Play("jump", true)
            AnimPlayer.QueuedAnim = "fall"
        elseif newState == Enum.HumanoidStateType.Freefall then
            if AnimPlayer.CurrentAnim ~= "jump" then
                AnimPlayer:Play("fall", true)
            end
        elseif newState == Enum.HumanoidStateType.Landed then
            AnimPlayer:Play("idle", true)
        end
    end))
    
    -- Dramatic entrance
    task.delay(0.5, function()
        PlayEntrance()
    end)
end

