local ChatSystem = {}

function ChatSystem:Setup()
    -- Legacy Chat System
    pcall(function()
        StarterGui:SetCore("ChatWindowConfiguration", {
            ChatWindowTextSize = 18,
        })
    end)
    
    -- TextChatService (modern chat)
    pcall(function()
        local textChatService = TextChatService
        if textChatService then
            textChatService.OnIncomingMessage = function(message)
                local props = Instance.new("TextChatMessageProperties")
                
                if message.TextSource then
                    local sourcePlayer = Players:GetPlayerByUserId(message.TextSource.UserId)
                    if sourcePlayer == Player then
                        props.PrefixText = "<font color='rgb(255,215,0)'>" .. CONFIG.PREFIX .. "</font> " .. message.PrefixText
                    end
                end
                
                return props
            end
        end
    end)
    
    -- Also try the callback approach
    pcall(function()
        if TextChatService.MessageReceived then
            -- Already handled above
        end
    end)
end

function ChatSystem:SendMessage(text)
    pcall(function()
        -- Try TextChatService first
        local channels = TextChatService:FindFirstChild("TextChannels")
        if channels then
            local rbxGeneral = channels:FindFirstChild("RBXGeneral")
            if rbxGeneral then
                rbxGeneral:SendAsync(text)
                return
            end
        end
    end)
    
    pcall(function()
        -- Fallback: legacy chat
        local chatRemote = ReplicatedStorage:FindFirstChild("DefaultChatSystemChatEvents")
        if chatRemote then
            local sayMsg = chatRemote:FindFirstChild("SayMessageRequest")
            if sayMsg then
                sayMsg:FireServer(text, "All")
            end
        end
    end)
end

function ChatSystem:MonitorChat()
    -- Monitor for "nah bro thinks he's the main character" type messages
    local function checkMessage(speaker, message)
        if speaker == Player.Name then return end
        
        local lower = string.lower(message)
        local triggers = {
            "thinks he",
            "main character",
            "nah bro",
            "who does he think",
            "not the main",
            "aint the main",
            "cringe",
        }
        
        local triggered = false
        for _, trigger in ipairs(triggers) do
            if lower:find(trigger) then
                triggered = true
                break
            end
        end
        
        if triggered and tick() - State.LastAutoChat > 5 then
            State.LastAutoChat = tick()
            
            -- Auto-respond
            task.delay(0.5, function()
                ChatSystem:SendMessage("EXCUSE ME!!?? \u{1F451}")
            end)
            
            -- Trigger extra dodge sequence
            State.ExtraDodgeMode = true
            State.ExtraDodgeEndTime = tick() + 4
            
            -- Play dramatic dodge sequence
            task.spawn(function()
                for i = 1, 3 do
                    if State.Character and State.Humanoid and State.Humanoid.Health > 0 then
                        PerformDodge()
                        task.wait(0.5)
                    end
                end
            end)
            
            -- Send follow-up
            task.delay(3, function()
                if tick() - State.LastAutoChat > 2 then
                    local responses = {
                        "I AM the main character. \u{1F451}\u{2728}",
                        "Check the title. \u{1F451}",
                        "This is MY story. \u{2728}\u{1F451}\u{2728}",
                    }
                    ChatSystem:SendMessage(responses[math.random(#responses)])
                end
            end)
        end
    end
    
    -- Listen to chat events
    pcall(function()
        -- TextChatService
        TextChatService.MessageReceived:Connect(function(msg)
            if msg.TextSource then
                local sourcePlayer = Players:GetPlayerByUserId(msg.TextSource.UserId)
                if sourcePlayer and sourcePlayer ~= Player then
                    checkMessage(sourcePlayer.Name, msg.Text or "")
                end
            end
        end)
    end)
    
    -- Legacy chat
    pcall(function()
        local chatEvents = ReplicatedStorage:FindFirstChild("DefaultChatSystemChatEvents")
        if chatEvents then
            local onMsg = chatEvents:FindFirstChild("OnMessageDoneFiltering")
            if onMsg then
                onMsg.OnClientEvent:Connect(function(data)
                    if data and data.FromSpeaker and data.Message then
                        checkMessage(data.FromSpeaker, data.Message)
                    end
                end)
            end
        end
    end)
    
    -- Player chatted event
    for _, plr in pairs(Players:GetPlayers()) do
        if plr ~= Player then
            pcall(function()
                plr.Chatted:Connect(function(msg)
                    checkMessage(plr.Name, msg)
                end)
            end)
        end
    end
    
    Players.PlayerAdded:Connect(function(plr)
        if plr ~= Player then
            pcall(function()
                plr.Chatted:Connect(function(msg)
                    checkMessage(plr.Name, msg)
                end)
            end)
        end
    end)
end

