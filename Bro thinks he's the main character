------------------------------------------------------------------------
local FallSystem = {}

function FallSystem:CheckFatalFall()
    if not State.RootPart or not State.Humanoid then return false end
    if State.IsLevitating or State.IsFalling then return false end
    
    local vel = State.RootPart.Velocity
    local falling = vel.Y < CONFIG.FALL_SPEED_THRESHOLD
    
    if falling then
        -- Raycast down to check distance to ground
        local rayOrigin = State.RootPart.Position
        local rayDirection = Vector3.new(0, -500, 0)
        local params = RaycastParams.new()
        params.FilterDescendantsInstances = {State.Character}
        params.FilterType = Enum.RaycastFilterType.Exclude
        
        local result = Workspace:Raycast(rayOrigin, rayDirection, params)
        
        if result then
            local distToGround = (rayOrigin - result.Position).Magnitude
            if distToGround > CONFIG.FALL_HEIGHT_THRESHOLD then
                return true
            end
        else
            -- No ground detected at all - definitely fatal
            return true
        end
    end
    
    -- Also check if we're about to hit void
    if State.RootPart.Position.Y < -50 then
        return true
    end
    
    return false
end

function FallSystem:PerformFallRecovery()
    if State.IsLevitating then return end
    State.IsFalling = true
    State.IsLevitating = true
    
    local rootPart = State.RootPart
    local humanoid = State.Humanoid
    if not rootPart or not humanoid then
        State.IsFalling = false
        State.IsLevitating = false
        return
    end
    
    -- Play roll animation first
    AnimPlayer:Play("roll", true)
    
    -- Show cinema bars
    CinemaSystem:Show()
    
    -- Stop all velocity
    local bodyVel = CreateInstance("BodyVelocity", {
        Name = "MCFallStop",
        Velocity = Vector3.new(0, 0, 0),
        MaxForce = Vector3.new(math.huge, math.huge, math.huge),
        P = 10000,
    }, rootPart)
    
    task.wait(0.6) -- Roll duration
    
    -- Now levitate back up
    AnimPlayer:Play("levitate", true)
    
    -- Find safe ground position
    local safeY = rootPart.Position.Y
    local rayOrigin = rootPart.Position + Vector3.new(0, 10, 0)
    local rayDirection = Vector3.new(0, -300, 0)
    local params = RaycastParams.new()
    params.FilterDescendantsInstances = {State.Character}
    params.FilterType = Enum.RaycastFilterType.Exclude
    
    local result = Workspace:Raycast(rayOrigin, rayDirection, params)
    if result then
        safeY = result.Position.Y + 3 + CONFIG.LEVITATE_HEIGHT_OFFSET
    else
        safeY = rootPart.Position.Y + 20
    end
    
    -- Smoothly levitate up
    local startPos = rootPart.Position
    local targetPos = Vector3.new(startPos.X, safeY, startPos.Z)
    
    local levitateTime = 0
    local levitateDuration = 2.0
    
    while levitateTime < levitateDuration do
        local dt = RunService.Heartbeat:Wait()
        levitateTime = levitateTime + dt
        
        local alpha = math.clamp(levitateTime / levitateDuration, 0, 1)
        -- Ease out cubic
        local easedAlpha = 1 - (1 - alpha) ^ 3
        
        local newPos = startPos:Lerp(targetPos, easedAlpha)
        bodyVel.Velocity = (newPos - rootPart.Position) * 10
        
        -- Gentle rotation
        local spinAngle = levitateTime * 0.5
    end
    
    -- Land softly
    bodyVel.Velocity = Vector3.new(0, -5, 0)
    task.wait(0.5)
    
    SafeDestroy(bodyVel)
    
    -- Hide cinema bars
    CinemaSystem:Hide()
    
    -- Return to idle
    AnimPlayer:Play("idle", true)
    
    State.IsFalling = false
    State.IsLevitating = false
end

------------------------------------------------------------------------
-- SMART DODGE SYSTEM
------------------------------------------------------------------------
local DodgeSystem = {}

function DodgeSystem:FindThreats()
    if not State.RootPart then return nil end
    
    local myPos = State.RootPart.Position
    local threats = {}
    
    -- Check for nearby players who might be attacking
    for _, plr in pairs(Players:GetPlayers()) do
        if plr ~= Player and plr.Character then
            local theirRoot = plr.Character:FindFirstChild("HumanoidRootPart")
            local theirHumanoid = plr.Character:FindFirstChildOfClass("Humanoid")
            
            if theirRoot and theirHumanoid then
                local dist = (theirRoot.Position - myPos).Magnitude
                
                if dist < CONFIG.DODGE_DETECTION_RADIUS then
                    -- Check if they're facing us and moving towards us
                    local dirToUs = (myPos - theirRoot.Position).Unit
                    local theirLookVector = theirRoot.CFrame.LookVector
                    local dot = dirToUs:Dot(theirLookVector)
                    
                    -- Check if they have a tool equipped (weapon)
                    local hasTool = plr.Character:FindFirstChildOfClass("Tool") ~= nil
                    
                    if dot > 0.5 and (hasTool or dist < 8) then
                        table.insert(threats, {
                            Position = theirRoot.Position,
                            Direction = theirLookVector,
                            Distance = dist,
                            HasWeapon = hasTool,
                            Priority = (hasTool and 2 or 1) * (1 / math.max(dist, 1)),
                        })
                    end
                end
            end
        end
    end
    
    -- Check for projectiles (parts moving fast towards us)
    local nearbyParts = Workspace:GetPartBoundsInRadius(myPos, CONFIG.PROJECTILE_DETECTION_RADIUS)
    for _, part in pairs(nearbyParts) do
        if part.Velocity.Magnitude > 30 then
            local velDir = part.Velocity.Unit
            local dirToUs = (myPos - part.Position).Unit
            local dot = velDir:Dot(dirToUs)
            
            if dot > 0.7 then
                local dist = (part.Position - myPos).Magnitude
                table.insert(threats, {
                    Position = part.Position,
                    Direction = velDir,
                    Distance = dist,
                    HasWeapon = true,
                    Priority = 3 * (1 / math.max(dist, 1)),
                    IsProjectile = true,
                })
            end
        end
    end
    
    -- Sort by priority
    table.sort(threats, function(a, b) return a.Priority > b.Priority end)
    
    return threats[1]
end

function PerformDodge(directionOverride)
    if State.IsDodging then return end
    if tick() - State.LastDodgeTime < CONFIG.DODGE_COOLDOWN then return end
    
    State.IsDodging = true
    State.LastDodgeTime = tick()
    State.DodgeCount = State.DodgeCount + 1
    
    local rootPart = State.RootPart
    if not rootPart then
        State.IsDodging = false
        return
    end
    
    -- Determine dodge direction
    local dodgeDir
    if directionOverride then
        dodgeDir = directionOverride
    else
        -- Dodge perpendicular to facing direction
        local lookVector = rootPart.CFrame.LookVector
        local side = (State.DodgeCount % 2 == 0) and 1 or -1
        dodgeDir = Vector3.new(-lookVector.Z * side, 0, lookVector.X * side).Unit
    end
    
    -- Play dodge animation
    AnimPlayer:Play("dodge", true)
    
    -- Apply dodge force
    local bodyVel = CreateInstance("BodyVelocity", {
        Name = "MCDodge",
        Velocity = dodgeDir * CONFIG.DODGE_SPEED + Vector3.new(0, 15, 0),
        MaxForce = Vector3.new(math.huge, math.huge, math.huge),
        P = 10000,
    }, rootPart)
    
    -- Brief slow-motion effect (camera FOV)
    local originalFOV = Camera.FieldOfView
    TweenService:Create(Camera, TweenInfo.new(0.1), {FieldOfView = originalFOV + 5}):Play()
    
    task.delay(0.15, function()
        if bodyVel and bodyVel.Parent then
            bodyVel.Velocity = dodgeDir * CONFIG.DODGE_SPEED * 0.3
        end
    end)
    
    task.delay(0.3, function()
        SafeDestroy(bodyVel)
        TweenService:Create(Camera, TweenInfo.new(0.2), {FieldOfView = originalFOV}):Play()
    end)
    
    task.delay(0.35, function()
        State.IsDodging = false
        if not State.IsLevitating then
            AnimPlayer:Play("idle", true)
        end
    end)
end

