local MotorManager = {}

function MotorManager:CollectMotors(character)
    State.Motors = {}
    
    if State.RigType == "R6" then
        local torso = character:FindFirstChild("Torso")
        local head = character:FindFirstChild("Head")
        local rootPart = character:FindFirstChild("HumanoidRootPart")
        
        if torso then
            for _, child in pairs(torso:GetChildren()) do
                if child:IsA("Motor6D") then
                    State.Motors[child.Name] = {
                        Motor = child,
                        C0_Original = child.C0,
                        C1_Original = child.C1,
                    }
                end
            end
        end
        if rootPart then
            for _, child in pairs(rootPart:GetChildren()) do
                if child:IsA("Motor6D") then
                    State.Motors[child.Name] = {
                        Motor = child,
                        C0_Original = child.C0,
                        C1_Original = child.C1,
                    }
                end
            end
        end
    else -- R15
        for _, desc in pairs(character:GetDescendants()) do
            if desc:IsA("Motor6D") then
                State.Motors[desc.Name] = {
                    Motor = desc,
                    C0_Original = desc.C0,
                    C1_Original = desc.C1,
                }
            end
        end
    end
end

function MotorManager:ApplyPoses(poses)
    for name, cf in pairs(poses) do
        local motorData = State.Motors[name]
        if motorData then
            pcall(function()
                motorData.Motor.C0 = motorData.C0_Original * cf
            end)
        end
    end
end

