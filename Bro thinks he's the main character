------------------------------------------------------------------------
-- ANIMATION PLAYER
------------------------------------------------------------------------
local AnimPlayer = {}
AnimPlayer.CurrentTime = 0
AnimPlayer.CurrentAnim = nil
AnimPlayer.AnimData = nil
AnimPlayer.Playing = false
AnimPlayer.QueuedAnim = nil
AnimPlayer.TargetPoses = {}
AnimPlayer.CurrentPoses = {}
AnimPlayer.StopMotionAccum = 0

function AnimPlayer:GetAnimSet()
    if State.RigType == "R15" then
        return Animations.R15
    else
        return Animations.R6
    end
end

function AnimPlayer:Play(animName, force)
    local animSet = self:GetAnimSet()
    if not animSet[animName] then return end
    if self.CurrentAnim == animName and not force then return end
    
    self.CurrentAnim = animName
    self.AnimData = animSet[animName]
    self.CurrentTime = 0
    self.Playing = true
    self.StopMotionAccum = 0
    State.CurrentAnim = animName
end

function AnimPlayer:Stop()
    self.Playing = false
    self.CurrentAnim = nil
    self.AnimData = nil
end

function AnimPlayer:InterpolateBetweenKeyframes(kf1, kf2, alpha)
    local result = {}
    local poses1 = kf1[2]
    local poses2 = kf2[2]
    
    local allKeys = {}
    for k in pairs(poses1) do allKeys[k] = true end
    for k in pairs(poses2) do allKeys[k] = true end
    
    for k in pairs(allKeys) do
        local cf1 = poses1[k] or CFrame.new()
        local cf2 = poses2[k] or CFrame.new()
        result[k] = cf1:Lerp(cf2, alpha)
    end
    
    return result
end

function AnimPlayer:GetCurrentPoses()
    if not self.AnimData or not self.Playing then return {} end
    
    local kfs = self.AnimData.Keyframes
    local duration = self.AnimData.Duration
    local t = self.CurrentTime
    
    if self.AnimData.Looping then
        t = t % duration
    else
        t = math.min(t, duration)
    end
    
    local normalizedT = t / duration
    
    local kf1, kf2
    for i = 1, #kfs - 1 do
        local t1 = kfs[i][1]
        local t2 = kfs[i + 1][1]
        if normalizedT >= t1 and normalizedT <= t2 then
            kf1 = kfs[i]
            kf2 = kfs[i + 1]
            break
        end
    end
    
    if not kf1 then
        if normalizedT <= kfs[1][1] then
            return kfs[1][2]
        else
            return kfs[#kfs][2]
        end
    end
    
    local range = kf2[1] - kf1[1]
    local alpha = 0
    if range > 0 then
        alpha = (normalizedT - kf1[1]) / range
    end
    
    -- Quantize alpha for stop-motion feel
    local steps = CONFIG.STOP_MOTION_FPS
    alpha = math.floor(alpha * steps) / steps
    
    return self:InterpolateBetweenKeyframes(kf1, kf2, alpha)
end

function AnimPlayer:Update(dt)
    if not self.Playing or not self.AnimData then return end
    
    -- Accumulate for frame delay effect
    self.StopMotionAccum = self.StopMotionAccum + dt
    local frameInterval = 1 / CONFIG.STOP_MOTION_FPS
    
    if self.StopMotionAccum >= frameInterval then
        self.StopMotionAccum = self.StopMotionAccum - frameInterval
        self.CurrentTime = self.CurrentTime + frameInterval * CONFIG.FRAME_DELAY * 0.5
    end
    
    local duration = self.AnimData.Duration
    if not self.AnimData.Looping and self.CurrentTime >= duration then
        self.Playing = false
        if self.QueuedAnim then
            self:Play(self.QueuedAnim, true)
            self.QueuedAnim = nil
        end
    end
    
    self.TargetPoses = self:GetCurrentPoses()
    
    -- Smooth interpolation with stop-motion snapping
    for name, targetCF in pairs(self.TargetPoses) do
        local current = self.CurrentPoses[name]
        if current then
            self.CurrentPoses[name] = current:Lerp(targetCF, CONFIG.ANIMATION_SMOOTHING)
        else
            self.CurrentPoses[name] = targetCF
        end
    end
end

