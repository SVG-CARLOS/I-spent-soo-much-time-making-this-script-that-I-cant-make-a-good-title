    for _, line in pairs(gui:GetChildren()) do
        if line:IsA("Frame") then
            line.BackgroundTransparency = 0.6
            TweenService:Create(line, TweenInfo.new(duration or 0.3, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
                BackgroundTransparency = 1
            }):Play()
        end
    end
end

------------------------------------------------------------------------
-- HEALTH MONITORING (for dodge trigger)
------------------------------------------------------------------------
local lastHealth = 100

local function OnHealthChanged(newHealth)
    if not State.Humanoid then return end
    
    if newHealth < lastHealth then
        -- We took damage, trigger dodge
        local threat = DodgeSystem:FindThreats()
        if threat then
            local dodgeDir = -threat.Direction
            dodgeDir = Vector3.new(-dodgeDir.Z, 0, dodgeDir.X).Unit
            PerformDodge(dodgeDir)
        else
            PerformDodge()
        end
        FlashSpeedLines(0.3)
    end
    
    lastHealth = newHealth
end

