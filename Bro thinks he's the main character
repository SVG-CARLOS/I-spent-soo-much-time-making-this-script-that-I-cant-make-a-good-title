------------------------------------------------------------------------
-- MAIN UPDATE LOOP
------------------------------------------------------------------------
local stepAccumulator = 0
local footstepAccumulator = 0

RunService.Heartbeat:Connect(function(dt)
    if not State.Character or not State.Humanoid or not State.RootPart then return end
    if State.Humanoid.Health <= 0 then return end
    
    -- Update animation player
    AnimPlayer:Update(dt)
    
    -- Apply animation poses to motors
    if AnimPlayer.CurrentPoses then
        MotorManager:ApplyPoses(AnimPlayer.CurrentPoses)
    end
    
    -- Determine movement state
    local vel = State.RootPart.Velocity
    local speed = Vector3.new(vel.X, 0, vel.Z).Magnitude
    local isMoving = speed > 1
    local isInAir = State.Humanoid:GetState() == Enum.HumanoidStateType.Freefall 
                    or State.Humanoid:GetState() == Enum.HumanoidStateType.Jumping
    
    -- Auto-switch animations based on state
    if not State.IsLevitating and not State.IsDodging and not State.IsFalling then
        if AnimPlayer.CurrentAnim ~= "hyped" and AnimPlayer.CurrentAnim ~= "entrance" and AnimPlayer.CurrentAnim ~= "roll" then
            if isInAir then
                if AnimPlayer.CurrentAnim ~= "jump" and AnimPlayer.CurrentAnim ~= "fall" then
                    AnimPlayer:Play("fall", false)
                end
            elseif isMoving then
                AnimPlayer:Play("walk", false)
            else
                AnimPlayer:Play("idle", false)
            end
        end
    end
    
    -- Footstep particles
    if footstepEmitter and isMoving and not isInAir then
        footstepAccumulator = footstepAccumulator + dt
        if footstepAccumulator > 0.3 then
            footstepAccumulator = 0
            footstepEmitter:Emit(3)
        end
    end
    
    -- Smart fall detection
    if not State.IsLevitating and not State.IsFalling then
        if FallSystem:CheckFatalFall() then
            task.spawn(function()
                FallSystem:PerformFallRecovery()
            end)
        end
    end
    
    -- Threat detection for auto-dodge
    stepAccumulator = stepAccumulator + dt
    if stepAccumulator > 0.15 then
        stepAccumulator = 0
        
        if not State.IsDodging and not State.IsLevitating then
            local threat = DodgeSystem:FindThreats()
            if threat and threat.Distance < 10 and threat.HasWeapon then
                local dodgeDir = Vector3.new(-threat.Direction.Z, 0, threat.Direction.X).Unit
                PerformDodge(dodgeDir)
                FlashSpeedLines(0.2)
            end
        end
    end
    
    -- Extra dodge mode (triggered by chat response)
    if State.ExtraDodgeMode and tick() > State.ExtraDodgeEndTime then
        State.ExtraDodgeMode = false
    end
    
    -- Animate accessories
    if State.AccessoriesEnabled then
        AccessorySystem:AnimateWings(dt)
        AccessorySystem:AnimateHalo(dt)
    end
end)

