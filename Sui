-- ============================================================
-- UTILITY FUNCTIONS
-- ============================================================
local Utils = {}

function Utils.DeepCopy(original)
    if type(original) ~= "table" then return original end
    local copy = {}
    for key, value in pairs(original) do
        copy[Utils.DeepCopy(key)] = Utils.DeepCopy(value)
    end
    return setmetatable(copy, getmetatable(original))
end

function Utils.SerializeVector3(v)
    if not v then return nil end
    return {x = math.round(v.X * 100) / 100, y = math.round(v.Y * 100) / 100, z = math.round(v.Z * 100) / 100}
end

function Utils.DeserializeVector3(t)
    if not t then return nil end
    return Vector3.new(t.x or 0, t.y or 0, t.z or 0)
end

function Utils.GetTimestamp()
    return tick()
end

function Utils.Distance(a, b)
    if not a or not b then return math.huge end
    return (a - b).Magnitude
end

function Utils.Lerp(a, b, t)
    return a + (b - a) * math.clamp(t, 0, 1)
end

function Utils.TableLength(t)
    local count = 0
    for _ in pairs(t) do count = count + 1 end
    return count
end

function Utils.StringSimilarity(s1, s2)
    s1 = string.lower(s1)
    s2 = string.lower(s2)
    if s1 == s2 then return 1.0 end
    
    local len1, len2 = #s1, #s2
    if len1 == 0 or len2 == 0 then return 0 end
    
    local maxLen = math.max(len1, len2)
    local matches = 0
    
    -- Simple word overlap
    local words1 = {}
    for word in s1:gmatch("%S+") do words1[word] = true end
    for word in s2:gmatch("%S+") do
        if words1[word] then matches = matches + 1 end
    end
    
    local totalWords = 0
    for _ in pairs(words1) do totalWords = totalWords + 1 end
    for word in s2:gmatch("%S+") do
        if not words1[word] then totalWords = totalWords + 1 end
    end
    
    if totalWords == 0 then return 0 end
    return matches / totalWords
end

function Utils.SafeCall(func, ...)
    local success, result = pcall(func, ...)
    if not success then
        warn("[MistralLearn] Error: " .. tostring(result))
        return nil, result
    end
    return result
end

function Utils.TruncateString(str, maxLen)
    if #str <= maxLen then return str end
    return string.sub(str, 1, maxLen - 3) .. "..."
end

