local Network = {}

function Network.MistralRequest(messages, temperature, maxTokens)
    if not State.MistralAPIKey then
        return nil, "No API key set"
    end
    
    temperature = temperature or 0.3
    maxTokens = maxTokens or 4096
    
    local payload = {
        model = CONFIG.MISTRAL_MODEL,
        messages = messages,
        temperature = temperature,
        max_tokens = maxTokens,
        top_p = 0.95,
    }
    
    local jsonPayload = HttpService:JSONEncode(payload)
    
    for attempt = 1, CONFIG.MAX_RETRIES do
        local success, response = pcall(function()
            return HttpService:RequestAsync({
                Url = CONFIG.MISTRAL_ENDPOINT,
                Method = "POST",
                Headers = {
                    ["Content-Type"] = "application/json",
                    ["Authorization"] = "Bearer " .. State.MistralAPIKey,
                },
                Body = jsonPayload,
            })
        end)
        
        if success then
            if response.StatusCode == 200 then
                local data = HttpService:JSONDecode(response.Body)
                if data.choices and data.choices[1] then
                    return data.choices[1].message.content, nil
                end
                return nil, "Invalid response structure"
            elseif response.StatusCode == 429 then
                UI.AddLog("Rate limited, waiting...", CONFIG.UI_COLORS.PROCESSING)
                task.wait(CONFIG.RATE_LIMIT_DELAY * attempt)
            else
                return nil, "HTTP " .. response.StatusCode .. ": " .. (response.Body or "Unknown error")
            end
        else
            if attempt < CONFIG.MAX_RETRIES then
                task.wait(1)
            else
                return nil, "Request failed: " .. tostring(response)
            end
        end
    end
    
    return nil, "Max retries exceeded"
end

function Network.LibYAGIRequest(data)
    if not State.LibYAGIKey then
        -- LibYAGI is optional - use local processing
        return Network.LocalAGIProcess(data)
    end
    
    local payload = {
        api_key = State.LibYAGIKey,
        data = data,
        mode = "learn",
    }
    
    local success, response = pcall(function()
        return HttpService:RequestAsync({
            Url = CONFIG.LIBYAGI_ENDPOINT,
            Method = "POST",
            Headers = {
                ["Content-Type"] = "application/json",
                ["Authorization"] = "Bearer " .. State.LibYAGIKey,
            },
            Body = HttpService:JSONEncode(payload),
        })
    end)
    
    if success and response.StatusCode == 200 then
        return HttpService:JSONDecode(response.Body)
    else
        -- Fallback to local processing
        return Network.LocalAGIProcess(data)
    end
end

function Network.LocalAGIProcess(data)
    -- Local pattern recognition when LibYAGI is unavailable
    local result = {
        patterns = {},
        insights = {},
        confidence = 0.7,
    }
    
    if data.actions then
        local actionTypes = {}
        for _, action in ipairs(data.actions) do
            local aType = action.type or "unknown"
            actionTypes[aType] = (actionTypes[aType] or 0) + 1
        end
        
        for aType, count in pairs(actionTypes) do
            if count >= 2 then
                table.insert(result.patterns, {
                    type = aType,
                    frequency = count,
                    confidence = math.min(count / #data.actions, 1),
                })
            end
        end
    end
    
    return result
end

function Network.ValidateMistralKey(key)
    local testMessages = {
        {role = "user", content = "Respond with only the word 'valid'"}
    }
    
    State.MistralAPIKey = key
    local response, err = Network.MistralRequest(testMessages, 0.0, 10)
    
    if response then
        return true
    else
        State.MistralAPIKey = nil
        return false, err
    end
end

