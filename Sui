function Executor.Interact(params)
    if params.target then
        local objects = EnvironmentScanner.FindObject(params.target)
        if #objects > 0 then
            local obj = objects[1]
            
            -- Move to object first
            if obj.position then
                Executor.Pathfind({position = {
                    x = obj.position.X,
                    y = obj.position.Y,
                    z = obj.position.Z
                }})
            end
            
            local method = params.method or "auto"
            
            if method == "auto" or method == "click" then
                local cd = obj.instance:FindFirstChildWhichIsA("ClickDetector", true)
                if cd then
                    fireclickdetector(cd)
                    UI.AddLog("  Interacted (click): " .. obj.name, CONFIG.UI_COLORS.SUCCESS)
                    return
                end
            end
            
            if method == "auto" or method == "prompt" then
                local pp = obj.instance:FindFirstChildWhichIsA("ProximityPrompt", true)
                if pp then
                    fireproximityprompt(pp)
                    UI.AddLog("  Interacted (prompt): " .. obj.name, CONFIG.UI_COLORS.SUCCESS)
                    return
                end
            end
            
            if method == "auto" or method == "touch" then
                -- Touch by moving to the exact position
                if obj.position then
                    Humanoid:MoveTo(obj.position)
                    Humanoid.MoveToFinished:Wait()
                    UI.AddLog("  Interacted (touch): " .. obj.name, CONFIG.UI_COLORS.SUCCESS)
                end
            end
        end
    end
end

