local EnvironmentScanner = {}

function EnvironmentScanner.ScanWorkspace()
    UI.AddLog("Scanning environment...", CONFIG.UI_COLORS.PROCESSING)
    
    local scan = {
        parts = {},
        models = {},
        tools = {},
        npcs = {},
        interactables = {},
        guis = {},
        spawn_points = {},
        terrain_info = {},
        total_objects = 0,
    }
    
    local function scanInstance(instance, depth)
        if depth > 15 then return end
        scan.total_objects = scan.total_objects + 1
        
        local info = {
            name = instance.Name,
            class = instance.ClassName,
            path = instance:GetFullName(),
        }
        
        if instance:IsA("BasePart") then
            info.position = Utils.SerializeVector3(instance.Position)
            info.size = Utils.SerializeVector3(instance.Size)
            info.anchored = instance.Anchored
            info.canCollide = instance.CanCollide
            info.material = instance.Material.Name
            info.color = tostring(instance.BrickColor)
            info.transparency = instance.Transparency
            
            -- Check for ClickDetectors
            if instance:FindFirstChildWhichIsA("ClickDetector") then
                info.clickable = true
                table.insert(scan.interactables, info)
            end
            
            -- Check for ProximityPrompts
            if instance:FindFirstChildWhichIsA("ProximityPrompt") then
                info.hasPrompt = true
                local prompt = instance:FindFirstChildWhichIsA("ProximityPrompt")
                info.promptAction = prompt.ActionText
                info.promptObject = prompt.ObjectText
                table.insert(scan.interactables, info)
            end
            
            table.insert(scan.parts, info)
            
        elseif instance:IsA("Model") then
            info.primaryPart = instance.PrimaryPart and instance.PrimaryPart.Name or nil
            if instance.PrimaryPart then
                info.position = Utils.SerializeVector3(instance.PrimaryPart.Position)
            end
            
            -- Check if it's an NPC
            local humanoid = instance:FindFirstChildWhichIsA("Humanoid")
            if humanoid and instance ~= Character then
                info.isNPC = true
                info.health = humanoid.Health
                info.maxHealth = humanoid.MaxHealth
                info.walkSpeed = humanoid.WalkSpeed
                table.insert(scan.npcs, info)
            end
            
            table.insert(scan.models, info)
            
        elseif instance:IsA("Tool") then
            info.requiresHandle = instance.RequiresHandle
            info.canBeDropped = instance.CanBeDropped
            table.insert(scan.tools, info)
            
        elseif instance:IsA("SpawnLocation") then
            info.position = Utils.SerializeVector3(instance.Position)
            table.insert(scan.spawn_points, info)
        end
        
        -- Store in knowledge base
        State.ObjectKnowledge[instance:GetFullName()] = info
        
        for _, child in ipairs(instance:GetChildren()) do
            scanInstance(child, depth + 1)
        end
    end
    
    -- Scan workspace
    for _, child in ipairs(Workspace:GetChildren()) do
        if child ~= Character then
            scanInstance(child, 0)
        end
    end
    
    -- Scan player's backpack for tools
    local backpack = LocalPlayer:FindFirstChild("Backpack")
    if backpack then
        for _, tool in ipairs(backpack:GetChildren()) do
            if tool:IsA("Tool") then
                table.insert(scan.tools, {
                    name = tool.Name,
                    class = "Tool",
                    location = "Backpack",
                    requiresHandle = tool.RequiresHandle,
                })
            end
        end
    end
    
    -- Scan GUIs
    for _, gui in ipairs(PlayerGui:GetChildren()) do
        if gui.Name ~= "MistralLearnUI" then
            local guiInfo = {name = gui.Name, class = gui.ClassName, buttons = {}, labels = {}}
            local function scanGui(element)
                if element:IsA("TextButton") or element:IsA("ImageButton") then
                    table.insert(guiInfo.buttons, {
                        name = element.Name,
                        text = element:IsA("TextButton") and element.Text or "",
                        visible = element.Visible,
                        path = element:GetFullName(),
                    })
                elseif element:IsA("TextLabel") then
                    table.insert(guiInfo.labels, {
                        name = element.Name,
                        text = element.Text,
                        visible = element.Visible,
                    })
                end
                for _, child in ipairs(element:GetChildren()) do
                    scanGui(child)
                end
            end
            scanGui(gui)
            table.insert(scan.guis, guiInfo)
        end
    end
    
    State.EnvironmentMap = scan
    UI.AddLog(string.format("Scan complete: %d objects, %d interactables, %d NPCs, %d tools", 
        scan.total_objects, #scan.interactables, #scan.npcs, #scan.tools), CONFIG.UI_COLORS.SUCCESS)
    
    return scan
end

function EnvironmentScanner.GetNearbyObjects(radius)
    radius = radius or 50
    local nearby = {}
    local pos = HumanoidRootPart.Position
    
    for _, part in ipairs(Workspace:GetDescendants()) do
        if part:IsA("BasePart") and part.Parent ~= Character then
            local dist = Utils.Distance(pos, part.Position)
            if dist <= radius then
                table.insert(nearby, {
                    name = part.Name,
                    class = part.ClassName,
                    distance = math.round(dist * 10) / 10,
                    position = Utils.SerializeVector3(part.Position),
                    parent = part.Parent and part.Parent.Name or "nil",
                    clickable = part:FindFirstChildWhichIsA("ClickDetector") ~= nil,
                    hasPrompt = part:FindFirstChildWhichIsA("ProximityPrompt") ~= nil,
                })
            end
        end
    end
    
    table.sort(nearby, function(a, b) return a.distance < b.distance end)
    return nearby
end

function EnvironmentScanner.FindObject(name)
    name = string.lower(name)
    local results = {}
    
    for _, obj in ipairs(Workspace:GetDescendants()) do
        if string.lower(obj.Name):find(name) then
            local info = {
                instance = obj,
                name = obj.Name,
                class = obj.ClassName,
                path = obj:GetFullName(),
            }
            if obj:IsA("BasePart") then
                info.position = obj.Position
            elseif obj:IsA("Model") and obj.PrimaryPart then
                info.position = obj.PrimaryPart.Position
            end
            table.insert(results, info)
        end
    end
    
    return results
end

