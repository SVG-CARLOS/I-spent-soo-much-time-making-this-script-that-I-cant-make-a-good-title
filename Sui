                    UI.AddLog("✅ Learned skill: " .. skill.name .. " (" .. 
                        math.floor((skill.confidence or 0) * 100) .. "% confidence)", CONFIG.UI_COLORS.SUCCESS)
                end
            end
            
            -- Store behaviors
            if analysis.behaviors then
                for _, behavior in ipairs(analysis.behaviors) do
                    State.LearnedPatterns[behavior.name] = behavior
                end
            end
            
            -- Store interactions
            if analysis.environment_interactions then
                for _, interaction in ipairs(analysis.environment_interactions) do
                    State.InteractionHistory[#State.InteractionHistory + 1] = interaction
                end
            end
            
            UI.AddLog("🧠 Analysis complete! " .. Utils.TableLength(State.SkillLibrary) .. 
                " skills, " .. Utils.TableLength(State.LearnedPatterns) .. " patterns", CONFIG.UI_COLORS.SUCCESS)
            
            if analysis.summary then
                UI.AddLog("📝 Summary: " .. Utils.TruncateString(analysis.summary, 200), CONFIG.UI_COLORS.ACCENT)
            end
        else
            UI.AddLog("⚠ Could not parse AI analysis, using local patterns", CONFIG.UI_COLORS.PROCESSING)
            -- Fall back to local patterns
            for name, pattern in pairs(patterns) do
                State.LearnedPatterns[name] = pattern
            end
        end
    else
        UI.AddLog("⚠ Mistral API error: " .. tostring(err), CONFIG.UI_COLORS.ERROR)
        UI.AddLog("Using local pattern analysis instead...", CONFIG.UI_COLORS.PROCESSING)
        for name, pattern in pairs(patterns) do
            State.LearnedPatterns[name] = pattern
        end
    end
    
    -- Phase 5: LibYAGI processing (optional enhancement)
    if State.LibYAGIKey then
        UI.AddLog("Phase 5: LibYAGI enhancement...", CONFIG.UI_COLORS.TEXT)
        local yagiResult = Network.LibYAGIRequest({
            actions = State.RecordedActions,
            patterns = patterns,
        })
        if yagiResult and yagiResult.patterns then
            for _, p in ipairs(yagiResult.patterns) do
                State.LearnedPatterns["yagi_" .. (p.type or "unknown")] = p
            end
        end
    end
    
    State.IsProcessing = false
    UI.UpdateStatus("Ready", CONFIG.UI_COLORS.SUCCESS)
    UI.UpdateStats()
    
    return true
end

function Brain.AnalyzePatterns(actions)
    local patterns = {}
    
    -- Count action types
    local typeCounts = {}
    local typeSequences = {}
    
    for i, action in ipairs(actions) do
        local aType = action.type
        typeCounts[aType] = (typeCounts[aType] or 0) + 1
        
        -- Track type sequences (pairs)
        if i > 1 then
            local prevType = actions[i-1].type
            local pair = prevType .. "->" .. aType
            typeSequences[pair] = (typeSequences[pair] or 0) + 1
        end
    end
    
    -- Identify frequent action types
    for aType, count in pairs(typeCounts) do
        if count >= 3 then
            patterns["frequent_" .. aType] = {
                type = aType,
                count = count,
                percentage = count / #actions,
                description = string.format("%s occurred %d times (%.0f%%)", aType, count, (count/#actions)*100),
            }
        end
    end
    
    -- Identify frequent sequences
    for pair, count in pairs(typeSequences) do
        if count >= 2 then
            patterns["sequence_" .. pair] = {
                sequence = pair,
                count = count,
                description = string.format("Sequence %s occurred %d times", pair, count),
            }
        end
    end
    
    -- Analyze movement patterns
    local moveActions = {}
    for _, action in ipairs(actions) do
        if action.type == "MOVEMENT" or action.type == "POSITION_SAMPLE" then
            table.insert(moveActions, action)
        end
    end
    
    if #moveActions > 2 then
        -- Calculate average speed and direction
        local totalSpeed = 0
        local speedCount = 0
        for _, ma in ipairs(moveActions) do
            if ma.speed then
                totalSpeed = totalSpeed + ma.speed
                speedCount = speedCount + 1
            end
        end
        
        if speedCount > 0 then
            patterns["movement_style"] = {
                averageSpeed = totalSpeed / speedCount,
                sampleCount = #moveActions,
                description = string.format("Average movement speed: %.1f", totalSpeed / speedCount),
            }
        end
    end
    
    -- Analyze click targets
    local clickTargets = {}
    for _, action in ipairs(actions) do
        if action.type == "MOUSE_CLICK" and action.target and action.target ~= "nil" then
            clickTargets[action.target] = (clickTargets[action.target] or 0) + 1
        end
    end
    
    for target, count in pairs(clickTargets) do
        patterns["click_target_" .. target] = {
            target = target,
            clickCount = count,
            description = string.format("Clicked on '%s' %d times", target, count),
        }
    end
    
    return patterns
end

function Brain.DetectSequences(actions)
    local sequences = {}
    local windowSize = 5
    
    for i = 1, #actions - windowSize + 1 do
        local seq = {}
        for j = i, i + windowSize - 1 do
            table.insert(seq, actions[j].type)
        end
        
        local seqKey = table.concat(seq, "|")
        sequences[seqKey] = (sequences[seqKey] or 0) + 1
    end
    
    -- Filter to repeated sequences
    local repeatedSeqs = {}
    for seqKey, count in pairs(sequences) do
        if count >= 2 then
            repeatedSeqs[seqKey] = {
                sequence = seqKey,
                count = count,
                actions = {},
            }
            for action in seqKey:gmatch("[^|]+") do
                table.insert(repeatedSeqs[seqKey].actions, action)
            end
        end
    end
    
    return repeatedSeqs
end

function Brain.SummarizeActions(actions)
    local summary = {}
    local maxSummaryActions = 150
    
    -- Sample actions if too many
    local sampled = actions
    if #actions > maxSummaryActions then
        sampled = {}
        local step = math.ceil(#actions / maxSummaryActions)
        for i = 1, #actions, step do
            table.insert(sampled, actions[i])
        end
    end
    
    for i, action in ipairs(sampled) do
        local line = string.format("%d. [%s]", i, action.type)
        
        if action.key then line = line .. " key=" .. action.key end
        if action.target and action.target ~= "nil" then line = line .. " target=" .. action.target end
        if action.toolName then line = line .. " tool=" .. action.toolName end
        if action.speed then line = line .. string.format(" speed=%.1f", action.speed) end
        if action.position then 
            line = line .. string.format(" pos=(%.0f,%.0f,%.0f)", 
                action.position.x or 0, action.position.y or 0, action.position.z or 0) 
        end
        if action.hitPosition then
            line = line .. string.format(" hit=(%.0f,%.0f,%.0f)",
                action.hitPosition.x or 0, action.hitPosition.y or 0, action.hitPosition.z or 0)
        end
        if action.subtype then line = line .. " sub=" .. action.subtype end
        if action.newState then line = line .. " state=" .. action.newState end
        
        table.insert(summary, line)
    end
    
    return table.concat(summary, "\n")
end

