local CommandProcessor = {}

function CommandProcessor.ProcessCommand(input)
    if not input or input == "" then return end
    
    input = input:gsub("^%s+", ""):gsub("%s+$", "")
    
    -- Check for special commands
    if input:lower() == "stop" or input:lower() == "cancel" then
        Executor.Stop()
        UI.AddLog("⏹ Execution stopped!", CONFIG.UI_COLORS.ACCENT)
        return
    end
    
    if input:lower() == "scan" then
        EnvironmentScanner.ScanWorkspace()
        return
    end
    
    if input:lower() == "nearby" then
        local nearby = EnvironmentScanner.GetNearbyObjects(50)
        UI.AddLog("📍 Nearby objects:", CONFIG.UI_COLORS.ACCENT)
        for i, obj in ipairs(nearby) do
            if i <= 20 then
                UI.AddLog(string.format("  %.1fm - %s (%s)%s%s", 
                    obj.distance, obj.name, obj.class,
                    obj.clickable and " [CLICK]" or "",
                    obj.hasPrompt and " [PROMPT]" or ""), CONFIG.UI_COLORS.TEXT)
            end
        end
        return
    end
    
    if input:lower() == "skills" then
        UI.AddLog("📚 Learned Skills:", CONFIG.UI_COLORS.ACCENT)
        if Utils.TableLength(State.SkillLibrary) == 0 then
            UI.AddLog("  No skills learned yet. Record and process actions first!", CONFIG.UI_COLORS.PROCESSING)
        else
            for name, skill in pairs(State.SkillLibrary) do
                UI.AddLog(string.format("  • %s (%.0f%%): %s", 
                    name, (skill.confidence or 0) * 100, skill.description or ""), CONFIG.UI_COLORS.TEXT)
            end
        end
        return
    end
    
    if input:lower() == "help" then
        UI.AddLog("📖 Commands:", CONFIG.UI_COLORS.ACCENT)
        UI.AddLog("  'stop' / 'cancel' - Stop current execution", CONFIG.UI_COLORS.TEXT)
        UI.AddLog("  'scan' - Rescan environment", CONFIG.UI_COLORS.TEXT)
        UI.AddLog("  'nearby' - List nearby objects", CONFIG.UI_COLORS.TEXT)
        UI.AddLog("  'skills' - List learned skills", CONFIG.UI_COLORS.TEXT)
        UI.AddLog("  'help' - Show this help", CONFIG.UI_COLORS.TEXT)
        UI.AddLog("  Anything else - AI will attempt to do it!", CONFIG.UI_COLORS.SUCCESS)
        return
    end
    
    -- Process with AI
    UI.AddLog("🤔 Thinking: \"" .. Utils.TruncateString(input, 100) .. "\"", CONFIG.UI_COLORS.PROCESSING)
    UI.UpdateStatus("Thinking", CONFIG.UI_COLORS.PROCESSING)
    
    spawn(function()
        local plan = CommandProcessor.GeneratePlan(input)
        if plan then
            Executor.ExecutePlan(plan)
        end
    end)
end

function CommandProcessor.GeneratePlan(userCommand)
    -- Build context
    Brain.BuildSystemPrompt()
    
    -- Get nearby objects for context
    local nearby = EnvironmentScanner.GetNearbyObjects(80)
    local nearbyStr = "NEARBY OBJECTS:\n"
    for i, obj in ipairs(nearby) do
        if i <= 30 then
            nearbyStr = nearbyStr .. string.format("- %s (%s) at %.1fm%s%s, parent=%s\n",
                obj.name, obj.class, obj.distance,
                obj.clickable and " [clickable]" or "",
                obj.hasPrompt and " [has prompt]" or "",
                obj.parent or "?")
        end
    end
    
    -- Player state
    Character = LocalPlayer.Character or LocalPlayer.CharacterAdded:Wait()
    Humanoid = Character:WaitForChild("Humanoid")
    HumanoidRootPart = Character:WaitForChild("HumanoidRootPart")
    
    local playerState = string.format([[
PLAYER STATE:
- Position: (%.1f, %.1f, %.1f)
- Health: %.0f/%.0f
- WalkSpeed: %.0f
- Currently equipped tool: %s
- State: %s
]], 
        HumanoidRootPart.Position.X, HumanoidRootPart.Position.Y, HumanoidRootPart.Position.Z,
        Humanoid.Health, Humanoid.MaxHealth,
        Humanoid.WalkSpeed,
        Character:FindFirstChildWhichIsA("Tool") and Character:FindFirstChildWhichIsA("Tool").Name or "None",
        Humanoid:GetState().Name
    )
    
    -- Build tools list
    local toolsList = "AVAILABLE TOOLS:\n"
    local backpack = LocalPlayer:FindFirstChild("Backpack")
    if backpack then
        for _, tool in ipairs(backpack:GetChildren()) do
            if tool:IsA("Tool") then
                toolsList = toolsList .. "- " .. tool.Name .. "\n"
            end
        end
    end
    local equippedTool = Character:FindFirstChildWhichIsA("Tool")
    if equippedTool then
        toolsList = toolsList .. "- " .. equippedTool.Name .. " [EQUIPPED]\n"
    end
    
    -- GUI info
    local guiInfo = "VISIBLE GUI ELEMENTS:\n"
    for _, gui in ipairs(PlayerGui:GetChildren()) do
        if gui.Name ~= "MistralLearnUI" and gui:IsA("ScreenGui") and gui.Enabled then
            for _, desc in ipairs(gui:GetDescendants()) do
                if desc.Visible and (desc:IsA("TextButton") or desc:IsA("ImageButton")) then
                    local text = desc:IsA("TextButton") and desc.Text or desc.Name
                    if text and text ~= "" then
                        guiInfo = guiInfo .. string.format("- Button: '%s' at %s\n", text, desc:GetFullName())
                    end
                end
            end
        end
    end
    
    local messages = {
        {role = "system", content = State.SystemPrompt},
        {role = "user", content = string.format([[
%s

%s

%s

%s

USER COMMAND: %s

Create a detailed action plan to accomplish this task. Consider the environment, nearby objects, available tools, and your learned skills. 
If the task seems impossible in this environment, explain why in the plan description but still attempt the closest possible actions.
Respond with valid JSON only.
]], playerState, nearbyStr, toolsList, guiInfo, userCommand)},
    }
    
    -- Add conversation history for context
    for _, msg in ipairs(State.ConversationHistory) do
        table.insert(messages, #messages, msg)
    end
    
    local response, err = Network.MistralRequest(messages, 0.4, 4096)
    
    if not response then
        UI.AddLog("❌ AI Error: " .. tostring(err), CONFIG.UI_COLORS.ERROR)
        return nil
    end
    
    -- Store in conversation history
    table.insert(State.ConversationHistory, {role = "user", content = userCommand})
    table.insert(State.ConversationHistory, {role = "assistant", content = response})
    
    -- Keep conversation history manageable
    while #State.ConversationHistory > 20 do
        table.remove(State.ConversationHistory, 1)
    end
    
    -- Parse JSON response
    local success, plan = pcall(function()
        local jsonStr = response:match("{.*}")
        if jsonStr then
            return HttpService:JSONDecode(jsonStr)
        end
        return nil
    end)
    
    if success and plan then
        UI.AddLog("📋 Plan: " .. (plan.plan or "Generated"), CONFIG.UI_COLORS.ACCENT)
        if plan.reasoning then
            UI.AddLog("💭 Reasoning: " .. Utils.TruncateString(plan.reasoning, 150), CONFIG.UI_COLORS.TEXT)
        end
        if plan.confidence then
            UI.AddLog(string.format("🎯 Confidence: %.0f%%", (plan.confidence or 0) * 100), CONFIG.UI_COLORS.TEXT)
        end
        return plan
    else
        -- Try to interpret as natural language plan
        UI.AddLog("⚠ Could not parse structured plan, attempting interpretation...", CONFIG.UI_COLORS.PROCESSING)
        
        -- Create a simple plan based on keywords in the response
        local simplePlan = CommandProcessor.InterpretNaturalResponse(response, userCommand)
        return simplePlan
    end
end

function CommandProcessor.InterpretNaturalResponse(response, originalCommand)
    -- Fallback: create basic action plan from keywords
    local plan = {
        plan = "Interpreted from AI response",
        actions = {},
        confidence = 0.5,
        reasoning = response,
    }
    
    local cmd = string.lower(originalCommand)
    
    -- Movement commands
    if cmd:find("go to") or cmd:find("walk to") or cmd:find("move to") or cmd:find("run to") then
        local target = cmd:match("go to (.+)") or cmd:match("walk to (.+)") or 
                       cmd:match("move to (.+)") or cmd:match("run to (.+)")
        if target then
            table.insert(plan.actions, {
                type = "PATHFIND",
                params = {target = target:gsub("^%s+", ""):gsub("%s+$", "")},
                description = "Navigate to " .. target,
            })
        end
    end
    
    -- Jump
    if cmd:find("jump") then
        table.insert(plan.actions, {
            type = "JUMP",
            params = {},
            description = "Jump",
        })
    end
    
    -- Click/interact
    if cmd:find("click") or cmd:find("interact") or cmd:find("use") or cmd:find("activate") then
        local target = cmd:match("click (.+)") or cmd:match("interact with (.+)") or 
                       cmd:match("use (.+)") or cmd:match("activate (.+)")
        if target then
            table.insert(plan.actions, {
                type = "INTERACT",
                params = {target = target:gsub("^%s+", ""):gsub("%s+$", ""), method = "auto"},
                description = "Interact with " .. target,
            })
        end
    end
    
    -- Equip tool
    if cmd:find("equip") or cmd:find("grab") or cmd:find("pick up") then
        local tool = cmd:match("equip (.+)") or cmd:match("grab (.+)") or cmd:match("pick up (.+)")
        if tool then
            table.insert(plan.actions, {
                type = "EQUIP_TOOL",
                params = {toolName = tool:gsub("^%s+", ""):gsub("%s+$", "")},
                description = "Equip " .. tool,
            })
        end
    end
    
    -- Chat
    if cmd:find("say") or cmd:find("chat") or cmd:find("tell") then
        local msg = cmd:match("say (.+)") or cmd:match("chat (.+)") or cmd:match("tell (.+)")
        if msg then
            table.insert(plan.actions, {
                type = "CHAT",
                params = {message = msg},
                description = "Send message",
            })
        end
    end
    
    -- If no actions were interpreted, create a generic scan + attempt
    if #plan.actions == 0 then
        table.insert(plan.actions, {
            type = "WAIT",
            params = {duration = 0.5},
            description = "Processing command...",
        })
        UI.AddLog("⚠ Could not interpret command. Try being more specific!", CONFIG.UI_COLORS.PROCESSING)
        UI.AddLog("  Examples: 'go to the red part', 'jump 3 times', 'click the door'", CONFIG.UI_COLORS.TEXT)
    end
    
    return plan
end

