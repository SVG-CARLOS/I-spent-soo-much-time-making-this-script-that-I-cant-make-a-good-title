local Recorder = {}

function Recorder.Start()
    if State.IsRecording then return end
    
    State.IsRecording = true
    State.RecordedActions = {}
    State.LastPosition = HumanoidRootPart.Position
    State.LastLookDirection = HumanoidRootPart.CFrame.LookVector
    
    UI.AddLog("🔴 RECORDING STARTED - Demonstrate actions!", CONFIG.UI_COLORS.RECORDING)
    UI.PulseRecording()
    
    if UI.Elements then
        UI.Elements.RecordBtn.Text = "⏹ STOP RECORDING"
    end
    
    -- Input recording connections
    Recorder._connections = {}
    
    -- Record keyboard inputs
    table.insert(Recorder._connections, UserInputService.InputBegan:Connect(function(input, gameProcessed)
        if not State.IsRecording then return end
        if input.UserInputType == Enum.UserInputType.Keyboard then
            Recorder.RecordAction({
                type = "KEY_PRESS",
                key = input.KeyCode.Name,
                gameProcessed = gameProcessed,
                timestamp = Utils.GetTimestamp(),
                position = Utils.SerializeVector3(HumanoidRootPart.Position),
                lookDir = Utils.SerializeVector3(HumanoidRootPart.CFrame.LookVector),
            })
        end
    end))
    
    table.insert(Recorder._connections, UserInputService.InputEnded:Connect(function(input, gameProcessed)
        if not State.IsRecording then return end
        if input.UserInputType == Enum.UserInputType.Keyboard then
            Recorder.RecordAction({
                type = "KEY_RELEASE",
                key = input.KeyCode.Name,
                gameProcessed = gameProcessed,
                timestamp = Utils.GetTimestamp(),
            })
        end
    end))
    
    -- Record mouse clicks
    table.insert(Recorder._connections, Mouse.Button1Down:Connect(function()
        if not State.IsRecording then return end
        local target = Mouse.Target
        Recorder.RecordAction({
            type = "MOUSE_CLICK",
            button = "Left",
            target = target and target.Name or "nil",
            targetClass = target and target.ClassName or "nil",
            targetPath = target and target:GetFullName() or "nil",
            targetParent = target and target.Parent and target.Parent.Name or "nil",
            hitPosition = Utils.SerializeVector3(Mouse.Hit.Position),
            timestamp = Utils.GetTimestamp(),
            playerPosition = Utils.SerializeVector3(HumanoidRootPart.Position),
        })
    end))
    
    table.insert(Recorder._connections, Mouse.Button2Down:Connect(function()
        if not State.IsRecording then return end
        Recorder.RecordAction({
            type = "MOUSE_CLICK",
            button = "Right",
            target = Mouse.Target and Mouse.Target.Name or "nil",
            hitPosition = Utils.SerializeVector3(Mouse.Hit.Position),
            timestamp = Utils.GetTimestamp(),
        })
    end))
    
    -- Record movement
    table.insert(Recorder._connections, Humanoid.Running:Connect(function(speed)
        if not State.IsRecording then return end
        if speed > 0.5 then
            Recorder.RecordAction({
                type = "MOVEMENT",
                subtype = "RUNNING",
                speed = speed,
                position = Utils.SerializeVector3(HumanoidRootPart.Position),
                direction = Utils.SerializeVector3(Humanoid.MoveDirection),
                timestamp = Utils.GetTimestamp(),
            })
        end
    end))
    
    -- Record jumping
    table.insert(Recorder._connections, Humanoid.Jumping:Connect(function(active)
        if not State.IsRecording and not active then return end
        Recorder.RecordAction({
            type = "JUMP",
            position = Utils.SerializeVector3(HumanoidRootPart.Position),
            velocity = Utils.SerializeVector3(HumanoidRootPart.Velocity),
            timestamp = Utils.GetTimestamp(),
        })
    end))
    
    -- Record state changes
    table.insert(Recorder._connections, Humanoid.StateChanged:Connect(function(oldState, newState)
        if not State.IsRecording then return end
        Recorder.RecordAction({
            type = "STATE_CHANGE",
            oldState = oldState.Name,
            newState = newState.Name,
            position = Utils.SerializeVector3(HumanoidRootPart.Position),
            timestamp = Utils.GetTimestamp(),
        })
    end))
    
    -- Record tool usage
    table.insert(Recorder._connections, Character.ChildAdded:Connect(function(child)
        if not State.IsRecording then return end
        if child:IsA("Tool") then
            Recorder.RecordAction({
                type = "TOOL_EQUIP",
                toolName = child.Name,
                timestamp = Utils.GetTimestamp(),
            })
        end
    end))
    
    table.insert(Recorder._connections, Character.ChildRemoved:Connect(function(child)
        if not State.IsRecording then return end
        if child:IsA("Tool") then
            Recorder.RecordAction({
                type = "TOOL_UNEQUIP",
                toolName = child.Name,
                timestamp = Utils.GetTimestamp(),
            })
        end
    end))
    
    -- Periodic position/state sampling
    spawn(function()
        while State.IsRecording do
            local currentPos = HumanoidRootPart.Position
            local moved = Utils.Distance(currentPos, State.LastPosition or currentPos)
            
            if moved > 2 then
                Recorder.RecordAction({
                    type = "POSITION_SAMPLE",
                    position = Utils.SerializeVector3(currentPos),
                    lookDir = Utils.SerializeVector3(HumanoidRootPart.CFrame.LookVector),
                    velocity = Utils.SerializeVector3(HumanoidRootPart.Velocity),
                    health = Humanoid.Health,
                    moveDirection = Utils.SerializeVector3(Humanoid.MoveDirection),
                    timestamp = Utils.GetTimestamp(),
                })
                State.LastPosition = currentPos
            end
            
            task.wait(CONFIG.RECORDING_TICK_RATE)
        end
    end)
end

function Recorder.Stop()
    if not State.IsRecording then return end
    
    State.IsRecording = false
    
    -- Disconnect all recording connections
    if Recorder._connections then
        for _, conn in ipairs(Recorder._connections) do
            if conn.Connected then
                conn:Disconnect()
            end
        end
        Recorder._connections = {}
    end
    
    if UI.Elements then
        UI.Elements.RecordBtn.Text = "⏺ START RECORDING"
        UI.Elements.RecordBtn.BackgroundColor3 = CONFIG.UI_COLORS.RECORDING
    end
    
    UI.AddLog(string.format("⏹ RECORDING STOPPED - %d actions captured", #State.RecordedActions), 
        CONFIG.UI_COLORS.SUCCESS)
end

function Recorder.RecordAction(action)
    if #State.RecordedActions < CONFIG.MAX_MEMORY_ENTRIES then
        action.frameCount = State.FrameCount
        table.insert(State.RecordedActions, action)
        
        -- Also add to persistent memory
        table.insert(State.ActionMemory, action)
        if #State.ActionMemory > CONFIG.MAX_MEMORY_ENTRIES then
            table.remove(State.ActionMemory, 1)
        end
    end
end

