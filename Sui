    State.SetupPhase = "READY"
    State.IsInitialized = true
    
    local elements = UI.Elements
    
    -- Hide setup, show controls
    elements.SetupPanel.Visible = false
    elements.ControlsPanel.Visible = true
    elements.LogPanel.Visible = true
    elements.CommandPanel.Visible = true
    elements.StatsPanel.Visible = true
    
    UI.UpdateStatus("Ready", CONFIG.UI_COLORS.SUCCESS)
    UI.AddLog("✅ Setup complete! System ready.", CONFIG.UI_COLORS.SUCCESS)
    UI.AddLog("━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━", CONFIG.UI_COLORS.TEXT)
    UI.AddLog("HOW TO USE:", CONFIG.UI_COLORS.ACCENT)
    UI.AddLog("1. Click 'START RECORDING' and demonstrate actions", CONFIG.UI_COLORS.TEXT)
    UI.AddLog("2. Click 'STOP RECORDING' when done", CONFIG.UI_COLORS.TEXT)
    UI.AddLog("3. Click 'PROCESS & LEARN' to analyze", CONFIG.UI_COLORS.TEXT)
    UI.AddLog("4. Type commands and the AI will execute them!", CONFIG.UI_COLORS.TEXT)
    UI.AddLog("5. Type 'help' for available commands", CONFIG.UI_COLORS.TEXT)
    UI.AddLog("━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━", CONFIG.UI_COLORS.TEXT)
    
    -- Initial environment scan
    spawn(function()
        task.wait(1)
        EnvironmentScanner.ScanWorkspace()
        Brain.BuildSystemPrompt()
    end)
    
    -- ========== CONNECT CONTROLS ==========
    
    -- Record button
    elements.RecordBtn.MouseButton1Click:Connect(function()
        if State.IsRecording then
            Recorder.Stop()
        else
            Recorder.Start()
        end
    end)
    
    -- Process button
    elements.ProcessBtn.MouseButton1Click:Connect(function()
        if State.IsProcessing then
            UI.AddLog("⚠ Already processing!", CONFIG.UI_COLORS.PROCESSING)
            return
        end
        if State.IsRecording then
            Recorder.Stop()
        end
        spawn(function()
            Brain.ProcessRecordedActions()
        end)
    end)
    
    -- Send command
    local function sendCommand()
        local text = elements.CommandInput.Text
        if text and text ~= "" then
            elements.CommandInput.Text = ""
            CommandProcessor.ProcessCommand(text)
        end
    end
    
    elements.SendBtn.MouseButton1Click:Connect(sendCommand)
    elements.CommandInput.FocusLost:Connect(function(enterPressed)
        if enterPressed then
            sendCommand()
        end
    end)
    
    -- Stats update loop
    spawn(function()
        while true do
            UI.UpdateStats()
            task.wait(2)
        end
    end)
end

