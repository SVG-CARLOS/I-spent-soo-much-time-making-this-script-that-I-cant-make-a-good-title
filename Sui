local Executor = {}

function Executor.ExecutePlan(plan)
    if State.IsExecuting then
        UI.AddLog("⚠ Already executing a plan!", CONFIG.UI_COLORS.PROCESSING)
        return
    end
    
    State.IsExecuting = true
    UI.AddLog("▶ Executing plan: " .. (plan.plan or "Unknown"), CONFIG.UI_COLORS.PRIMARY)
    
    spawn(function()
        local success = true
        
        for i, action in ipairs(plan.actions or {}) do
            if not State.IsExecuting then
                UI.AddLog("⏹ Execution cancelled", CONFIG.UI_COLORS.ERROR)
                break
            end
            
            UI.AddLog(string.format("  Step %d/%d: %s - %s", 
                i, #plan.actions, action.type, action.description or ""), CONFIG.UI_COLORS.TEXT)
            
            local actionSuccess = Executor.ExecuteAction(action)
            
            if not actionSuccess then
                UI.AddLog("  ⚠ Step " .. i .. " had issues, continuing...", CONFIG.UI_COLORS.PROCESSING)
            end
            
            task.wait(0.2) -- Brief pause between actions
        end
        
        State.IsExecuting = false
        UI.AddLog("✅ Plan execution complete!", CONFIG.UI_COLORS.SUCCESS)
        UI.UpdateStatus("Ready", CONFIG.UI_COLORS.SUCCESS)
    end)
end

function Executor.ExecuteAction(action)
    local actionType = action.type
    local params = action.params or {}
    
    local handlers = {
        MOVE_TO = Executor.MoveTo,
        CLICK = Executor.Click,
        KEY_PRESS = Executor.KeyPress,
        EQUIP_TOOL = Executor.EquipTool,
        USE_TOOL = Executor.UseTool,
        JUMP = Executor.Jump,
        INTERACT = Executor.Interact,
        CHAT = Executor.ChatMessage,
        WAIT = Executor.Wait,
        LOOK_AT = Executor.LookAt,
        CLICK_GUI = Executor.ClickGUI,
        PATHFIND = Executor.Pathfind,
        EMOTE = Executor.Emote,
        CUSTOM = Executor.Custom,
    }
    
    local handler = handlers[actionType]
    if handler then
        local success, err = pcall(handler, params)
        if not success then
            UI.AddLog("  ❌ Action error: " .. tostring(err), CONFIG.UI_COLORS.ERROR)
            return false
        end
        return true
    else
        UI.AddLog("  ❓ Unknown action type: " .. tostring(actionType), CONFIG.UI_COLORS.ERROR)
        return false
    end
end

function Executor.MoveTo(params)
    -- Refresh character references
    Character = LocalPlayer.Character or LocalPlayer.CharacterAdded:Wait()
    Humanoid = Character:WaitForChild("Humanoid")
    HumanoidRootPart = Character:WaitForChild("HumanoidRootPart")
    
    local targetPos
    
    if params.target then
        local objects = EnvironmentScanner.FindObject(params.target)
        if #objects > 0 and objects[1].position then
            targetPos = objects[1].position
        else
            UI.AddLog("  Could not find target: " .. params.target, CONFIG.UI_COLORS.ERROR)
            return
        end
    elseif params.x and params.y and params.z then
        targetPos = Vector3.new(params.x, params.y, params.z)
    else
        return
    end
    
    Humanoid:MoveTo(targetPos)
    
    local reached = Humanoid.MoveToFinished:Wait()
    if not reached then
        -- Try pathfinding as fallback
        Executor.Pathfind({position = {x = targetPos.X, y = targetPos.Y, z = targetPos.Z}})
    end
end

function Executor.Pathfind(params)
    Character = LocalPlayer.Character or LocalPlayer.CharacterAdded:Wait()
    Humanoid = Character:WaitForChild("Humanoid")
    HumanoidRootPart = Character:WaitForChild("HumanoidRootPart")
    
    local targetPos
    
    if params.target then
        local objects = EnvironmentScanner.FindObject(params.target)
        if #objects > 0 and objects[1].position then
            targetPos = objects[1].position
        else
            UI.AddLog("  Pathfind target not found: " .. params.target, CONFIG.UI_COLORS.ERROR)
            return
        end
    elseif params.position then
        targetPos = Vector3.new(params.position.x or 0, params.position.y or 0, params.position.z or 0)
    elseif params.x then
        targetPos = Vector3.new(params.x, params.y or 0, params.z or 0)
    else
        return
    end
    
    local path = PathfindingService:CreatePath({
        AgentRadius = 2,
        AgentHeight = 5,
        AgentCanJump = true,
        AgentCanClimb = true,
    })
    
    local success, err = pcall(function()
        path:ComputeAsync(HumanoidRootPart.Position, targetPos)
    end)
    
    if not success then
        UI.AddLog("  Pathfinding error: " .. tostring(err), CONFIG.UI_COLORS.ERROR)
        -- Fallback to direct movement
        Humanoid:MoveTo(targetPos)
        Humanoid.MoveToFinished:Wait()
        return
    end
    
    if path.Status == Enum.PathStatus.Success then
        local waypoints = path:GetWaypoints()
        
        for _, waypoint in ipairs(waypoints) do
            if not State.IsExecuting then break end
            
            if waypoint.Action == Enum.PathWaypointAction.Jump then
                Humanoid.Jump = true
            end
            
            Humanoid:MoveTo(waypoint.Position)
            
            local timeOut = tick() + CONFIG.PATHFINDING_TIMEOUT
            local reached = false
            
            while not reached and tick() < timeOut and State.IsExecuting do
                local dist = Utils.Distance(HumanoidRootPart.Position, waypoint.Position)
                if dist < 4 then
                    reached = true
                end
                task.wait(0.1)
            end
        end
    else
        UI.AddLog("  Path not found, using direct movement", CONFIG.UI_COLORS.PROCESSING)
        Humanoid:MoveTo(targetPos)
        Humanoid.MoveToFinished:Wait()
    end
end

function Executor.Click(params)
    if params.target then
        local objects = EnvironmentScanner.FindObject(params.target)
        for _, obj in ipairs(objects) do
            local instance = obj.instance
            
            -- Try ClickDetector
            local clickDetector = instance:FindFirstChildWhichIsA("ClickDetector", true)
            if clickDetector then
                -- Move close enough first
                if obj.position then
                    local dist = Utils.Distance(HumanoidRootPart.Position, obj.position)
                    if dist > clickDetector.MaxActivationDistance then
                        Executor.Pathfind({position = {
                            x = obj.position.X, 
                            y = obj.position.Y, 
                            z = obj.position.Z
                        }})
                    end
                end
                
                fireclickdetector(clickDetector)
                UI.AddLog("  Clicked: " .. obj.name, CONFIG.UI_COLORS.SUCCESS)
                return
            end
            
            -- Try ProximityPrompt
            local prompt = instance:FindFirstChildWhichIsA("ProximityPrompt", true)
            if prompt then
                if obj.position then
                    local dist = Utils.Distance(HumanoidRootPart.Position, obj.position)
                    if dist > prompt.MaxActivationDistance then
                        Executor.Pathfind({position = {
                            x = obj.position.X,
                            y = obj.position.Y,
                            z = obj.position.Z
                        }})
                    end
                end
                
                fireproximityprompt(prompt)
                UI.AddLog("  Activated prompt: " .. obj.name, CONFIG.UI_COLORS.SUCCESS)
                return
            end
        end
    end
end

function Executor.KeyPress(params)
    local keyName = params.key
    local duration = params.duration or 0.1
    
    local keyCode = Enum.KeyCode[keyName]
    if keyCode then
        -- Simulate key press using VirtualInputManager if available
        -- Otherwise use humanoid controls
        local vim = game:GetService("VirtualInputManager")
        if vim then
            pcall(function()
                vim:SendKeyEvent(true, keyCode, false, game)
                task.wait(duration)
                vim:SendKeyEvent(false, keyCode, false, game)
            end)
        else
            -- Fallback: interpret common keys
            if keyName == "Space" then
                Humanoid.Jump = true
            elseif keyName == "W" then
                Humanoid:Move(Vector3.new(0, 0, -1))
                task.wait(duration)
                Humanoid:Move(Vector3.new(0, 0, 0))
            elseif keyName == "S" then
                Humanoid:Move(Vector3.new(0, 0, 1))
                task.wait(duration)
                Humanoid:Move(Vector3.new(0, 0, 0))
            elseif keyName == "A" then
                Humanoid:Move(Vector3.new(-1, 0, 0))
                task.wait(duration)
                Humanoid:Move(Vector3.new(0, 0, 0))
            elseif keyName == "D" then
                Humanoid:Move(Vector3.new(1, 0, 0))
                task.wait(duration)
                Humanoid:Move(Vector3.new(0, 0, 0))
            end
        end
        
        UI.AddLog("  Key pressed: " .. keyName, CONFIG.UI_COLORS.TEXT)
    end
end

function Executor.EquipTool(params)
    local toolName = params.toolName or params.name
    if not toolName then return end
    
    local backpack = LocalPlayer:FindFirstChild("Backpack")
    if backpack then
        local tool = backpack:FindFirstChild(toolName)
        if tool and tool:IsA("Tool") then
            Humanoid:EquipTool(tool)
            UI.AddLog("  Equipped: " .. toolName, CONFIG.UI_COLORS.SUCCESS)
            return
        end
    end
    
    -- Search by partial name
    if backpack then
        for _, item in ipairs(backpack:GetChildren()) do
            if item:IsA("Tool") and string.lower(item.Name):find(string.lower(toolName)) then
                Humanoid:EquipTool(item)
                UI.AddLog("  Equipped: " .. item.Name, CONFIG.UI_COLORS.SUCCESS)
                return
            end
        end
    end
    
    UI.AddLog("  Tool not found: " .. toolName, CONFIG.UI_COLORS.ERROR)
end

