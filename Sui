local function Initialize()
    -- Create UI
    UI.Create()
    
    UI.AddLog("🚀 Mistral Learn v2.0 initializing...", CONFIG.UI_COLORS.PRIMARY)
    UI.AddLog("Welcome! Let's set up your AI assistant.", CONFIG.UI_COLORS.TEXT)
    
    -- ========== SETUP FLOW ==========
    local elements = UI.Elements
    
    -- Handle API Key submission
    elements.SubmitKeyBtn.MouseButton1Click:Connect(function()
        local key = elements.APIKeyInput.Text
        
        if key == "" then
            elements.SetupStatus.Text = "⚠ Please enter a key!"
            elements.SetupStatus.TextColor3 = CONFIG.UI_COLORS.ERROR
            return
        end
        
        if State.SetupPhase == "AWAITING_MISTRAL_KEY" then
            elements.SetupStatus.Text = "🔄 Validating Mistral API key..."
            elements.SetupStatus.TextColor3 = CONFIG.UI_COLORS.PROCESSING
            elements.SubmitKeyBtn.Text = "⏳ Validating..."
            
            spawn(function()
                local valid, err = Network.ValidateMistralKey(key)
                
                if valid then
                    State.MistralAPIKey = key
                    State.SetupPhase = "AWAITING_LIBYAGI_KEY"
                    
                    UI.AddLog("✅ Mistral API key validated!", CONFIG.UI_COLORS.SUCCESS)
                    
                    elements.SetupLabel.Text = "🔑 Enter your LibYAGI Key (optional):"
                    elements.APIKeyInput.Text = ""
                    elements.APIKeyInput.PlaceholderText = "LibYAGI key (press Skip if none)..."
                    elements.SubmitKeyBtn.Text = "✓ Submit Key"
                    elements.SetupStatus.Text = "Step 2/2: LibYAGI Key (optional - enhances learning)"
                    elements.SetupStatus.TextColor3 = CONFIG.UI_COLORS.ACCENT
                    
                    -- Add skip button
                    local SkipBtn = Instance.new("TextButton")
                    SkipBtn.Name = "SkipBtn"
                    SkipBtn.Size = UDim2.new(0.48, 0, 0, 35)
                    SkipBtn.Position = UDim2.new(0.51, 0, 0, 95)
                    SkipBtn.BackgroundColor3 = CONFIG.UI_COLORS.SECONDARY
                    SkipBtn.BorderSizePixel = 0
                    SkipBtn.Text = "⏭ Skip"
                    SkipBtn.TextColor3 = CONFIG.UI_COLORS.TEXT
                    SkipBtn.TextSize = 14
                    SkipBtn.Font = Enum.Font.GothamBold
                    SkipBtn.Parent = elements.SetupPanel
                    
                    local SkipCorner = Instance.new("UICorner")
                    SkipCorner.CornerRadius = UDim.new(0, 8)
                    SkipCorner.Parent = SkipBtn
                    
                    elements.SubmitKeyBtn.Size = UDim2.new(0.48, 0, 0, 35)
                    
                    SkipBtn.MouseButton1Click:Connect(function()
                        CompleteSetup()
                    end)
                else
                    elements.SetupStatus.Text = "❌ Invalid key: " .. tostring(err)
                    elements.SetupStatus.TextColor3 = CONFIG.UI_COLORS.ERROR
                    elements.SubmitKeyBtn.Text = "✓ Submit Key"
                    UI.AddLog("❌ Mistral key validation failed: " .. tostring(err), CONFIG.UI_COLORS.ERROR)
                end
            end)
            
        elseif State.SetupPhase == "AWAITING_LIBYAGI_KEY" then
            State.LibYAGIKey = key
            UI.AddLog("✅ LibYAGI key saved!", CONFIG.UI_COLORS.SUCCESS)
            CompleteSetup()
        end
    end)
    
    -- Character respawn handling
    LocalPlayer.CharacterAdded:Connect(function(char)
        Character = char
        Humanoid = char:WaitForChild("Humanoid")
        HumanoidRootPart = char:WaitForChild("HumanoidRootPart")
        UI.AddLog("🔄 Character respawned, references updated", CONFIG.UI_COLORS.TEXT)
    end)
    
    -- Frame counter
    RunService.Heartbeat:Connect(function()
        State.FrameCount = State.FrameCount + 1
    end)
end

