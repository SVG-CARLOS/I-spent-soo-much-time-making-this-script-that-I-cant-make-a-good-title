local function getMyRoot()
	local c = player.Character
	return c and c:FindFirstChild("HumanoidRootPart")
end

local function getMyHumanoid()
	local c = player.Character
	return c and c:FindFirstChildOfClass("Humanoid")
end

local function getTargetRoot()
	if not selectedTarget then
		local others = getOtherPlayers()
		if #others > 0 then
			selectedTarget = others[math.random(1, #others)]
			setTarget(selectedTarget)
		end
	end
	if selectedTarget and selectedTarget.Character then
		return selectedTarget.Character:FindFirstChild("HumanoidRootPart")
	end
	return nil
end

local function flashScreen(col, dur, maxAlpha)
	local f = Instance.new("Frame")
	f.Size = UDim2.new(1, 0, 1, 0)
	f.BackgroundColor3 = col
	f.BackgroundTransparency = 1 - (maxAlpha or 0.4)
	f.BorderSizePixel = 0
	f.ZIndex = 200
	f.Parent = screenGui
	TweenService:Create(f, TweenInfo.new(dur or 0.3), {BackgroundTransparency = 1}):Play()
	Debris:AddItem(f, dur or 0.3)
end

local function spawnSmoke(pos, col, amount, spread, life)
	local p = Instance.new("Part")
	p.Size = Vector3.new(0.5, 0.5, 0.5)
	p.Transparency = 1
	p.Anchored = true
	p.CanCollide = false
	p.Position = pos
	p.Parent = workspace

	local pe = Instance.new("ParticleEmitter")
	pe.Color = ColorSequence.new(col or Color3.fromRGB(20, 0, 0))
	pe.Size = NumberSequence.new({NumberSequenceKeypoint.new(0, spread or 3), NumberSequenceKeypoint.new(1, 0)})
	pe.Transparency = NumberSequence.new({NumberSequenceKeypoint.new(0, 0.2), NumberSequenceKeypoint.new(1, 1)})
	pe.Lifetime = NumberRange.new((life or 1) * 0.5, life or 1)
	pe.Rate = amount or 80
	pe.Speed = NumberRange.new(2, 6)
	pe.SpreadAngle = Vector2.new(360, 360)
	pe.RotSpeed = NumberRange.new(-90, 90)
	pe.Parent = p

	task.delay(0.25, function() pe.Rate = 0 end)
	Debris:AddItem(p, (life or 1) + 0.5)
	return p
end

local function shakeCamera(intensity, duration, decay)
	spawn(function()
		local elapsed = 0
		while elapsed < duration do
			local dt = RunService.RenderStepped:Wait()
			elapsed = elapsed + dt
			local factor = intensity * (1 - (elapsed / duration))
			if decay then factor = intensity * math.exp(-elapsed * decay) end
			camera.CFrame = camera.CFrame * CFrame.new(
				(math.random() - 0.5) * factor,
				(math.random() - 0.5) * factor,
				0
			) * CFrame.Angles(
				math.rad((math.random() - 0.5) * factor * 2),
				math.rad((math.random() - 0.5) * factor * 2),
				math.rad((math.random() - 0.5) * factor)
			)
		end
	end)
end

