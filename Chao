createAbilityButton("Phantom Surround", "Ghostly copies encircle the target", 12, 8, function()
	local tRoot = getTargetRoot()
	local myChar = player.Character
	if not tRoot or not myChar then return end

	myChar.Archivable = true
	local clones = {}

	for i = 1, 5 do
		local clone = myChar:Clone()
		for _, obj in pairs(clone:GetDescendants()) do
			if obj:IsA("BasePart") then
				obj.Anchored = true
				obj.CanCollide = false
				obj.Transparency = 0.6
				obj.Material = Enum.Material.Neon
				obj.Color = Color3.fromRGB(20 + math.random(0, 15), 0, 0)
			elseif obj:IsA("BaseScript") or obj:IsA("Decal") or obj:IsA("Accessory") then
				obj:Destroy()
			end
		end

		local angle = (math.pi * 2 / 5) * i
		local dist = 10
		local pos = tRoot.Position + Vector3.new(math.cos(angle) * dist, 0, math.sin(angle) * dist)
		local lookCF = CFrame.lookAt(pos, tRoot.Position)
		clone:SetPrimaryPartCFrame(lookCF)
		clone.Parent = workspace
		table.insert(clones, {clone = clone, angle = angle, dist = dist, spawnTime = tick()})

		spawn(function()
			for _, part in pairs(clone:GetDescendants()) do
				if part:IsA("BasePart") then
					part.Transparency = 1
					TweenService:Create(part, TweenInfo.new(0.4), {Transparency = 0.55}):Play()
				end
			end
		end)
	end

	spawn(function()
		local duration = 6
		local startTime = tick()
		while tick() - startTime < duration do
			local elapsed = tick() - startTime
			local tr = getTargetRoot()
			if not tr then break end
			for _, data in pairs(clones) do
				if data.clone and data.clone.Parent then
					local a = data.angle + elapsed * 0.8
					local d = data.dist - elapsed * 0.6
					d = math.max(d, 4)
					local pos = tr.Position + Vector3.new(math.cos(a) * d, math.sin(elapsed * 3) * 0.5, math.sin(a) * d)
					local cf = CFrame.lookAt(pos, tr.Position)
					data.clone:SetPrimaryPartCFrame(cf)
				end
			end
			RunService.Heartbeat:Wait()
		end

		for _, data in pairs(clones) do
			if data.clone and data.clone.Parent then
				for _, part in pairs(data.clone:GetDescendants()) do
					if part:IsA("BasePart") then
						TweenService:Create(part, TweenInfo.new(0.6), {Transparency = 1}):Play()
					end
				end
				Debris:AddItem(data.clone, 0.7)
			end
		end
	end)
end)

