spawn(function()
	local t = 0
	while true do
		t = t + RunService.Heartbeat:Wait()
		local pulse = (math.sin(t * 2) + 1) / 2
		orbStroke.Color = lerpColor(colorAccentDim, colorAccent, pulse)
		orbInner.BackgroundTransparency = lerp(0.5, 0.1, pulse)
		if mainFrame.Visible then
			mainStroke.Color = lerpColor(colorAccentDim, colorAccent, pulse * 0.5)
		end
	end
end)

