	pe.Rate = 40
	pe.Speed = NumberRange.new(1, 3)
	pe.SpreadAngle = Vector2.new(360, 10)
	pe.Acceleration = Vector3.new(0, 2, 0)
	pe.Parent = ring

	spawn(function()
