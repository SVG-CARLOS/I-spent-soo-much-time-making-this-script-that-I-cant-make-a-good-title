local function twitchEntity()
	local tr = getTargetRoot()
	if not tr then sysMsg("No target selected.") return end

	S.glitch:Play()
	showStalker(0)

	for i = 1, 40 do
		tr = getTargetRoot()
		if not tr then break end

		local dist = math.random(3, 15)
		local angle = math.random() * math.pi * 2
		local pos = tr.Position + Vector3.new(math.cos(angle)*dist, math.random(-2, 4), math.sin(angle)*dist)

		poseStalker(lookAtCF(pos, tr.Position), math.random() > 0.5 and "reach" or "idle")

		if math.random() < 0.3 then
			showStalker(0)
		else
			showStalker(math.random() * 0.5)
		end

		staticBurst(0.02, 0.2)
		task.wait(0.04 + math.random() * 0.06)
	end

	hideStalker()
end

