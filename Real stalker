local function behindYou()
	local tr = getTargetRoot()
	if not tr then sysMsg("No target selected.") return end

	S.breathing.Volume = 0.5
	S.breathing:Play()
	S.heartbeat.Volume = 0.4
	S.heartbeat.PlaybackSpeed = 0.9
	S.heartbeat:Play()

	local dist = 12
	showStalker(0.35)

	sendChat("I'm right behind you.")
	showMsg("BEHIND YOU", 2.5, 62)

	task.wait(0.5)
	flashRed(0.15, 0.3)
	task.wait(1.5)

	sendChat("Don't turn around.")

	local start = tick()
	local rushed = false

	while tick() - start < 18 and not rushed do
		tr = getTargetRoot()
		if not tr then break end

		dist = math.max(3, dist - 0.04)
		local behindPos = getBehind(tr, dist)
		behindPos = Vector3.new(behindPos.X, tr.Position.Y, behindPos.Z)
		poseStalker(lookAtCF(behindPos, tr.Position), "creep")

		local alpha = 1 - dist/12
		showStalker(0.35 - alpha * 0.3)

		S.heartbeat.Volume = 0.4 + alpha * 0.8
		S.heartbeat.PlaybackSpeed = 0.9 + alpha * 1.2

		if math.random() < 0.06 then
			S.step.PlaybackSpeed = 0.4 + math.random() * 0.3
			S.step.Volume = 0.2 + alpha * 0.4
			S.step:Play()
		end

		if isLooking(tr, stalkerFolder:FindFirstChild("Torso").Position) then
			rushed = true

			sendChat("TOO LATE.")
			S.screech:Play()
			S.jumpscare:Play()

			showStalker(0)

			local rushStart = torso.Position
			for i = 1, 25 do
				tr = getTargetRoot()
				if not tr then break end
				local t = (i/25)
				local eased = t * t * t
				local pos = rushStart:Lerp(tr.Position + tr.CFrame.LookVector * 1.5, eased)
				poseStalker(lookAtCF(pos, tr.Position), "rush")

				shake(t * 6, 0.03)
				Camera.FieldOfView = 70 - t * 25

				if math.random() < 0.4 then staticBurst(0.03, 0.5 + t * 0.4) end

				task.wait(0.018)
			end

			Camera.FieldOfView = 70
			blackout.BackgroundTransparency = 0
			jsImage.ImageTransparency = 0
			jsImage.BackgroundTransparency = 0

			shake(14, 0.8)

			for i = 1, 10 do
				jsImage.ImageTransparency = (i%2 == 0) and 0 or 0.4
				flashRed(0.03, 0.9)
				jsImage.Position = UDim2.new(-0.1 + (math.random()-0.5)*0.08, 0, -0.1 + (math.random()-0.5)*0.08, 0)
				jsImage.Rotation = (math.random()-0.5) * 15
				task.wait(0.05)
			end

			showMsg("YOU SHOULD HAVE LISTENED", 3, 58)

			task.wait(1.5)

			tween(jsImage, 0.8, {ImageTransparency = 1, BackgroundTransparency = 1}):Play()
			jsImage.Position = UDim2.new(-0.1, 0, -0.1, 0)
			jsImage.Rotation = 0
			task.wait(0.5)
			tween(blackout, 3, {BackgroundTransparency = 1}):Play()
		end

		if not rushed then task.wait(0.035) end
	end

	if not rushed then
		hideStalker()
		sendChat("Lucky. This time.")
		showMsg("...", 2, 44)
	else
		task.wait(2)
		hideStalker()
	end

	tween(S.heartbeat, 1.5, {Volume = 0}):Play()
	tween(S.breathing, 1, {Volume = 0}):Play()
	task.wait(1.5)
	S.heartbeat:Stop()
	S.breathing:Stop()
end

local function startStalk()
	if stalking then
		stalking = false
		if stalkConn then stalkConn:Disconnect() stalkConn = nil end
		hideStalker()
		S.creepy:Stop()
		S.heartbeat:Stop()
		return
	end
	stalking = true
	S.creepy:Play()
	S.heartbeat.Volume = 0.25
	S.heartbeat.PlaybackSpeed = 0.7
	S.heartbeat:Play()

	local stalkDist = 40
	showStalker(0.4)

	stalkConn = RunService.RenderStepped:Connect(function()
		if not stalking then return end
		local tr = getTargetRoot()
		if not tr then return end

		stalkDist = math.max(10, stalkDist - 0.01)

		local lateralOff = math.sin(tick() * 0.25) * 18
		local offset = -tr.CFrame.LookVector * stalkDist + tr.CFrame.RightVector * lateralOff
		local pos = tr.Position + offset
		pos = Vector3.new(pos.X, tr.Position.Y, pos.Z)

		poseStalker(lookAtCF(pos, tr.Position), "walk")

		local looking = isLooking(tr, torso.Position)
		if looking then
			showStalker(0.6 + math.sin(tick()*8)*0.15)
			if math.random() < 0.03 then staticBurst(0.08, 0.15) end
		else
			showStalker(0.25 - (1 - stalkDist/40) * 0.15)
		end

		local d = (torso.Position - tr.Position).Magnitude
		S.heartbeat.Volume = math.clamp(1 - d/50, 0.15, 1)
		S.heartbeat.PlaybackSpeed = math.clamp(2 - d/30, 0.6, 2.2)

		if math.random() < 0.004 then
			S.step.PlaybackSpeed = 0.4 + math.random()*0.3
			S.step:Play()
		end
	end)
end

local function deathRush()
	local tr = getTargetRoot()
	if not tr then sysMsg("No target selected.") return end

	sendChat("Your time has come.")
	task.wait(1.5)

	S.heartbeat.Volume = 0.8
	S.heartbeat.PlaybackSpeed = 1.2
	S.heartbeat:Play()

	vignette.ImageTransparency = 0.3

	for i = 1, 8 do
		flashRed(0.08, 0.4 + i*0.05)
		shake(i * 0.5, 0.15)
		S.heartbeat.PlaybackSpeed = 1.2 + i * 0.12
		task.wait(0.6 - i * 0.05)
	end

	tr = getTargetRoot()
	if not tr then return end

	local spawnPos = tr.Position + tr.CFrame.LookVector * 50 + Vector3.new(0, 8, 0)
	showStalker(0)
	poseStalker(lookAtCF(spawnPos, tr.Position), "reach")

	sendChat("HERE I COME.")
	S.screech:Play()
	S.boom:Play()

	for i = 1, 35 do
		tr = getTargetRoot()
		if not tr then break end
		local t = i/35
		local eased = t < 0.5 and 2*t*t or 1 - (-2*t+2)^2/2
		local pos = spawnPos:Lerp(tr.Position, eased)
		poseStalker(lookAtCF(pos, tr.Position), "rush")

		Camera.FieldOfView = 70 - t * 30
		shake(t * 8, 0.02)

		eyeLight1.Range = 12 + t * 30
		eyeLight2.Range = 12 + t * 30
		eyeLight1.Brightness = 4 + t * 20
		eyeLight2.Brightness = 4 + t * 20

		if t > 0.5 then staticBurst(0.02, t * 0.6) end
		if t > 0.7 and math.random() < 0.5 then subliminal(0.02) end

		task.wait(0.015)
	end

	Camera.FieldOfView = 70
	eyeLight1.Range = 12
	eyeLight2.Range = 12
	eyeLight1.Brightness = 4
	eyeLight2.Brightness = 4

	blackout.BackgroundTransparency = 0
	jsImage.ImageTransparency = 0
	jsImage.BackgroundTransparency = 0
	S.jumpscare:Play()
	shake(16, 1)

	for i = 1, 12 do
		jsImage.ImageTransparency = (i%2==0) and 0 or 0.3
		jsImage.Position = UDim2.new(-0.1+(math.random()-0.5)*0.1, 0, -0.1+(math.random()-0.5)*0.1, 0)
		jsImage.Rotation = (math.random()-0.5)*20
		flashRed(0.02, 1)
		task.wait(0.04)
	end

	showMsg("G A M E   O V E R", 3, 70)

	task.wait(2)
	tween(jsImage, 1, {ImageTransparency = 1, BackgroundTransparency = 1}):Play()
	jsImage.Position = UDim2.new(-0.1, 0, -0.1, 0)
	jsImage.Rotation = 0
	task.wait(1)
	tween(blackout, 3, {BackgroundTransparency = 1}):Play()
	tween(vignette, 1, {ImageTransparency = 1}):Play()
	hideStalker()
	S.heartbeat:Stop()
end

local function countdown()
	local tr = getTargetRoot()
	if not tr then sysMsg("No target selected.") return end

	S.heartbeat.Volume = 0.3
	S.heartbeat.PlaybackSpeed = 0.7
	S.heartbeat:Play()
	S.drone:Play()

	sendChat("10...")

	for i = 10, 1, -1 do
		local intensity = (11 - i) / 10
		showMsg(tostring(i), 0.7, 60 + intensity * 50)

		S.heartbeat.Volume = 0.3 + intensity * 1.2
		S.heartbeat.PlaybackSpeed = 0.7 + intensity * 1.8

		flashRed(0.1, intensity * 0.6)
		shake(intensity * 4, 0.2)
		fovPulse(intensity * 12, 0.3)

		if i <= 5 then
			staticBurst(0.08, intensity * 0.5)
			if i <= 3 then sendChat(i .. "...") end
			if i <= 2 then subliminal(0.04) end
		end

		cc.Saturation = -intensity * 0.8
		vignette.ImageTransparency = 1 - intensity * 0.6

		task.wait(1 - intensity * 0.3)
	end

	S.screech:Play()
	S.jumpscare:Play()
	S.boom:Play()

	tr = getTargetRoot()
