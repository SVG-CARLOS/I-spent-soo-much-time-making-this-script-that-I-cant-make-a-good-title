local function sendChat(msg)
	pcall(function()
		local ch = TextChatService:FindFirstChild("TextChannels")
		if ch then
			local g = ch:FindFirstChild("RBXGeneral")
			if g then g:SendAsync(msg) end
		end
	end)
end

local function sysMsg(msg)
