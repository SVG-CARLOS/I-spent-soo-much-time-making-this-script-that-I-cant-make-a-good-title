local function heartbeatEsc()
	S.heartbeat.Volume = 0.2
	S.heartbeat.PlaybackSpeed = 0.5
	S.heartbeat:Play()
	vignette.ImageTransparency = 0.5

	for i = 1, 35 do
		local t = i/35
		S.heartbeat.Volume = 0.2 + t * 1.5
		S.heartbeat.PlaybackSpeed = 0.5 + t * 2

		vignette.ImageTransparency = 0.5 - t * 0.45

		local pulse = math.abs(math.sin(tick() * (S.heartbeat.PlaybackSpeed * 3)))
		redFlash.BackgroundTransparency = 1 - t * 0.4 * pulse

		if t > 0.5 then shake(t * 3.5, 0.08) end
		if t > 0.7 then staticBurst(0.04, t * 0.4) end
		if t > 0.85 then fovPulse(t * 10, 0.15) end

		task.wait(0.25 - t * 0.18)
	end

	S.screech:Play()
	S.jumpscare:Play()
	blackout.BackgroundTransparency = 0
	flashRed(0.5, 1)
	shake(12, 0.6)
	subliminal(0.06)

	task.wait(1.5)
	tween(blackout, 2.5, {BackgroundTransparency = 1}):Play()
	vignette.ImageTransparency = 1
	redFlash.BackgroundTransparency = 1
	S.heartbeat:Stop()
end

