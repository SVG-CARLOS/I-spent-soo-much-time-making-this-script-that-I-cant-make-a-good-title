		body.CFrame = lookAtCF(pos, tr.Position)
		eyes.CFrame = body.CFrame * CFrame.new(0, 2.8, -0.5)

		body.Parent = Camera
		eyes.Parent = Camera
		table.insert(shadows, {body=body, eyes=eyes})
	end

	S.creepy.Volume = 0.5
	S.creepy:Play()
	S.heartbeat.Volume = 0.4
	S.heartbeat:Play()

	for step = 1, 50 do
		tr = getTargetRoot()
		if not tr then break end
		for _, s in pairs(shadows) do
			local dir = (tr.Position - s.body.Position).Unit
			s.body.CFrame = lookAtCF(s.body.Position + dir * 0.35, tr.Position)
			s.eyes.CFrame = s.body.CFrame * CFrame.new(0, 2.8, -0.5)
			s.body.Transparency = 0.3 + math.sin(tick()*4 + _)*0.15
		end
		if step%12 == 0 then flashRed(0.05, 0.3) end
		S.heartbeat.Volume = 0.4 + step/50 * 0.8
		S.heartbeat.PlaybackSpeed = 0.7 + step/50 * 1.3
		task.wait(0.08)
	end

	S.screech:Play()
	flashRed(0.3, 0.8)
	shake(10, 0.5)

	for _, s in pairs(shadows) do
		tween(s.body, 0.6, {Transparency = 1}):Play()
		tween(s.eyes, 0.6, {Transparency = 1}):Play()
	end
	task.wait(1)
	for _, s in pairs(shadows) do
		s.body:Destroy()
		s.eyes:Destroy()
	end
	S.creepy:Stop()
	S.heartbeat:Stop()
end

