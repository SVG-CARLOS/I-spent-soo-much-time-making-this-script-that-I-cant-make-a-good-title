local function poseStalker(cf, animState)
	animTick = animTick + 0.03
	local t = animTick

	local breathe = math.sin(t * 1.5) * 0.08
	local sway = math.sin(t * 0.7) * 0.02

	local baseCF = cf * CFrame.new(0, breathe, 0) * CFrame.Angles(0, 0, sway)

	torso.CFrame = baseCF
	head.CFrame = baseCF * CFrame.new(0, 2.5 + math.sin(t * 2) * 0.03, 0) * CFrame.Angles(math.sin(t * 0.8) * 0.05, math.sin(t * 0.5) * 0.08, math.sin(t * 1.2) * 0.03)

	local headCF = head.CFrame
	leftEye.CFrame = headCF * CFrame.new(-0.3, 0.1, -0.75)
	rightEye.CFrame = headCF * CFrame.new(0.3, 0.1, -0.75)
	mouth.CFrame = headCF * CFrame.new(0, -0.4, -0.75)

	local lArmSwing, rArmSwing = 0, 0
	local lArmReach, rArmReach = 0, 0

	if animState == "idle" then
		lArmSwing = math.sin(t * 1.2) * 0.15
		rArmSwing = math.sin(t * 1.2 + 1) * 0.15
	elseif animState == "walk" then
		lArmSwing = math.sin(t * 6) * 0.6
		rArmSwing = math.sin(t * 6 + math.pi) * 0.6
	elseif animState == "rush" then
		lArmReach = -1.2
		rArmReach = -1.2
		lArmSwing = math.sin(t * 15) * 0.3
		rArmSwing = math.sin(t * 15 + math.pi) * 0.3
	elseif animState == "creep" then
		lArmSwing = math.sin(t * 0.5) * 0.1
		rArmSwing = math.sin(t * 0.5 + 2) * 0.1
		lArmReach = -0.3
		rArmReach = -0.3
	elseif animState == "reach" then
		lArmReach = -1.5 + math.sin(t * 3) * 0.1
		rArmReach = -1.5 + math.sin(t * 3 + 1) * 0.1
	end

	lArm.CFrame = baseCF * CFrame.new(-1.4, 0.8, 0) * CFrame.Angles(lArmReach + lArmSwing, 0, math.rad(-8) + math.sin(t * 0.9) * 0.03)
	rArm.CFrame = baseCF * CFrame.new(1.4, 0.8, 0) * CFrame.Angles(rArmReach + rArmSwing, 0, math.rad(8) + math.sin(t * 0.9 + 1) * 0.03)

	local lArmEnd = lArm.CFrame * CFrame.new(0, -2.1, 0)
	lClaw1.CFrame = lArmEnd * CFrame.new(-0.12, -0.4, -0.1) * CFrame.Angles(math.rad(-20) + math.sin(t * 3) * 0.05, 0, math.rad(-10))
	lClaw2.CFrame = lArmEnd * CFrame.new(0, -0.45, -0.1) * CFrame.Angles(math.rad(-25) + math.sin(t * 3.2) * 0.05, 0, 0)
	lClaw3.CFrame = lArmEnd * CFrame.new(0.12, -0.4, -0.1) * CFrame.Angles(math.rad(-20) + math.sin(t * 2.8) * 0.05, 0, math.rad(10))

	local rArmEnd = rArm.CFrame * CFrame.new(0, -2.1, 0)
	rClaw1.CFrame = rArmEnd * CFrame.new(-0.12, -0.4, -0.1) * CFrame.Angles(math.rad(-20) + math.sin(t * 3) * 0.05, 0, math.rad(-10))
	rClaw2.CFrame = rArmEnd * CFrame.new(0, -0.45, -0.1) * CFrame.Angles(math.rad(-25) + math.sin(t * 3.2) * 0.05, 0, 0)
	rClaw3.CFrame = rArmEnd * CFrame.new(0.12, -0.4, -0.1) * CFrame.Angles(math.rad(-20) + math.sin(t * 2.8) * 0.05, 0, math.rad(10))

	if animState == "walk" or animState == "rush" then
		local legSpeed = animState == "rush" and 12 or 5
		lLeg.CFrame = baseCF * CFrame.new(-0.45, -3.3, 0) * CFrame.Angles(math.sin(t * legSpeed) * 0.7, 0, 0)
		rLeg.CFrame = baseCF * CFrame.new(0.45, -3.3, 0) * CFrame.Angles(math.sin(t * legSpeed + math.pi) * 0.7, 0, 0)
	else
		lLeg.CFrame = baseCF * CFrame.new(-0.45, -3.3, 0) * CFrame.Angles(math.sin(t * 0.8) * 0.03, 0, math.rad(-2))
		rLeg.CFrame = baseCF * CFrame.new(0.45, -3.3, 0) * CFrame.Angles(math.sin(t * 0.8 + 1) * 0.03, 0, math.rad(2))
	end

	if animState == "rush" then
		local flicker = math.random() > 0.2
		leftEye.Color = flicker and Color3.fromRGB(255, 0, 0) or Color3.fromRGB(255, 255, 255)
		rightEye.Color = flicker and Color3.fromRGB(255, 0, 0) or Color3.fromRGB(255, 255, 255)
		eyeLight1.Brightness = 6 + math.random() * 4
		eyeLight2.Brightness = 6 + math.random() * 4
		mouth.Size = Vector3.new(0.6, 0.15 + math.sin(t * 20) * 0.05, 0.06)
	else
		leftEye.Color = Color3.fromRGB(255, 0, 0)
		rightEye.Color = Color3.fromRGB(255, 0, 0)
		eyeLight1.Brightness = 3 + math.sin(t * 2) * 1
		eyeLight2.Brightness = 3 + math.sin(t * 2 + 0.5) * 1
		mouth.Size = Vector3.new(0.6, 0.08, 0.06)
	end
end

local function showStalker(trans)
	stalkerVisible = true
	trans = trans or 0
	for _, p in pairs(allParts) do
		if p.Name == "LEye" or p.Name == "REye" or p.Name == "Mouth" or p.Name:match("C%d") then
			p.Transparency = math.max(0, trans - 0.1)
		else
			p.Transparency = trans
		end
	end
	eyeLight1.Enabled = true
	eyeLight2.Enabled = true
	smoke.Enabled = true
	redMist.Enabled = true
end

local function hideStalker()
	stalkerVisible = false
	for _, p in pairs(allParts) do
		p.Transparency = 1
	end
	eyeLight1.Enabled = false
	eyeLight2.Enabled = false
	smoke.Enabled = false
	redMist.Enabled = false
end

local function lookAtCF(pos, target)
	local lookTarget = Vector3.new(target.X, pos.Y, target.Z)
	return CFrame.new(pos, lookTarget)
end

