local function tween(obj, time, props, style, dir)
	return TweenService:Create(obj, TweenInfo.new(time, style or Enum.EasingStyle.Quad, dir or Enum.EasingDirection.Out), props)
end

local function flashRed(dur, power)
	redFlash.BackgroundTransparency = 1 - (power or 0.4)
	task.delay(dur or 0.15, function()
		tween(redFlash, 0.3, {BackgroundTransparency = 1}):Play()
	end)
end

local function flashWhite(dur)
	whiteFlash.BackgroundTransparency = 0
	task.delay(dur or 0.05, function()
		tween(whiteFlash, 0.2, {BackgroundTransparency = 1}):Play()
	end)
end

local function staticBurst(dur, power)
	staticImg.ImageTransparency = 1 - (power or 0.4)
	S.static.Volume = power or 0.4
	S.static:Play()
	task.spawn(function()
		local e = 0
		while e < (dur or 0.3) do
			staticImg.Position = UDim2.new(-0.15 + (math.random()-0.5)*0.03, 0, -0.15 + (math.random()-0.5)*0.03, 0)
			e = e + task.wait()
		end
		tween(staticImg, 0.2, {ImageTransparency = 1}):Play()
		staticImg.Position = UDim2.new(-0.15, 0, -0.15, 0)
		S.static:Stop()
	end)
end

local function showMsg(text, dur, size)
	msgLabel.Text = text
	msgLabel.TextSize = size or 52
	msgLabel.TextTransparency = 0
	msgLabel.TextStrokeTransparency = 0
	task.spawn(function()
		local e = 0
		while e < (dur or 2) do
			msgLabel.Position = UDim2.new(0.05 + (math.random()-0.5)*0.008, 0, 0.4 + (math.random()-0.5)*0.008, 0)
			msgLabel.Rotation = (math.random()-0.5)*2
			e = e + task.wait()
		end
		tween(msgLabel, 0.6, {TextTransparency = 1, TextStrokeTransparency = 1}):Play()
		task.wait(0.6)
		msgLabel.Position = UDim2.new(0.05, 0, 0.4, 0)
		msgLabel.Rotation = 0
	end)
end

local function shake(intensity, dur)
	task.spawn(function()
		local e = 0
		while e < (dur or 0.5) do
			local frac = 1 - e/(dur or 0.5)
			local i = (intensity or 3) * frac
			Camera.CFrame = Camera.CFrame * CFrame.new((math.random()-0.5)*i, (math.random()-0.5)*i, (math.random()-0.5)*i) * CFrame.Angles((math.random()-0.5)*math.rad(i), (math.random()-0.5)*math.rad(i), (math.random()-0.5)*math.rad(i*0.5))
			e = e + RunService.RenderStepped:Wait()
		end
	end)
end

local function subliminal(dur)
	jsImage.ImageTransparency = 0
	jsImage.BackgroundTransparency = 0
	task.wait(dur or 0.06)
	jsImage.ImageTransparency = 1
	jsImage.BackgroundTransparency = 1
end

local function fovPulse(amount, dur)
	task.spawn(function()
		local orig = Camera.FieldOfView
		local e = 0
		while e < (dur or 0.5) do
			local frac = math.sin((e / (dur or 0.5)) * math.pi)
			Camera.FieldOfView = orig + (amount or 15) * frac
			e = e + RunService.RenderStepped:Wait()
		end
		Camera.FieldOfView = 70
	end)
end

local function isLooking(tRoot, pos)
	local dir = (pos - tRoot.Position).Unit
	return tRoot.CFrame.LookVector:Dot(dir) > 0.25
end

local function getBehind(tRoot, dist)
	return tRoot.Position - tRoot.CFrame.LookVector * (dist or 10)
end

