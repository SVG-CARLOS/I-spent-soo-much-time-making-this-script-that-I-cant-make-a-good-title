-- FEATURE: BEHIND YOU
-- ═══════════════════════════════════════════════════════

local behindYouActive = false

local function behindYouSequence()
	if behindYouActive then return end
	behindYouActive = true

	local targetRoot = getTargetRoot()
	if not targetRoot then
		behindYouActive = false
		return
	end

	sounds.Breathing:Play()
	sounds.Heartbeat.Volume = 0.5
	sounds.Heartbeat:Play()

	local behindPos = getPositionBehind(targetRoot, 10)
	showStalker(0.4)
	updateStalkerPose(behindPos, targetRoot.Position)

	sendChat("I'm right behind you.")

	showMessage("BEHIND YOU", 2, 56)
	flashScreen(Color3.new(0.3, 0, 0), 0.2, 0.4)

	task.wait(1)

	sendChat("Don't turn around.")

	task.wait(1.5)

	local rushed = false
	local checkStart = tick()

	while tick() - checkStart < 15 and not rushed and behindYouActive do
		targetRoot = getTargetRoot()
		if not targetRoot then break end

		behindPos = getPositionBehind(targetRoot, 10 - (tick() - checkStart) * 0.3)
		behindPos = Vector3.new(behindPos.X, targetRoot.Position.Y, behindPos.Z)
		updateStalkerPose(behindPos, targetRoot.Position)

		local stalkerPos = stalkerTorso.Position
		if isPlayerLookingAtStalker(targetRoot, stalkerPos) then
			rushed = true

			sendChat("TOO LATE.")
			sounds.Jumpscare:Play()

			local rushFrames = 20
			for i = 1, rushFrames do
				targetRoot = getTargetRoot()
				if not targetRoot then break end
				local t = i / rushFrames
				local rushPos = stalkerPos:Lerp(targetRoot.Position + targetRoot.CFrame.LookVector * 2, t)
				updateStalkerPose(rushPos, targetRoot.Position)

				showStalker(0)

				local eyeFlicker = math.random() > 0.3
				leftEye.Color = eyeFlicker and Color3.new(1, 0, 0) or Color3.new(1, 1, 1)
				rightEye.Color = eyeFlicker and Color3.new(1, 0, 0) or Color3.new(1, 1, 1)

				task.wait(0.02)
			end

			blackScreen.BackgroundTransparency = 0
			subliminalFlash(0.1)
			shakeCamera(8, 0.5)
			staticBurst(0.8, 0.7)

			showMessage("YOU SHOULD HAVE LISTENED", 3, 52)

			task.wait(0.5)

			for i = 1, 5 do
				subliminalFlash(0.04)
				task.wait(0.08)
			end

			task.wait(1)
			TweenService:Create(blackScreen, TweenInfo.new(2), {BackgroundTransparency = 1}):Play()
		end

		if not rushed then
			local dist = (stalkerTorso.Position - targetRoot.Position).Magnitude
			sounds.Heartbeat.Volume = math.clamp(1 - dist / 20, 0.2, 1.5)
			sounds.Heartbeat.PlaybackSpeed = math.clamp(2 - dist / 15, 0.8, 2)

			if dist < 5 then
				sounds.Breathing.Volume = 0.8
			end

			if math.random() < 0.1 then
				sounds.Footstep.PlaybackSpeed = 0.6 + math.random() * 0.4
				sounds.Footstep:Play()
			end
		end

		task.wait(0.05)
	end

	if not rushed then
		hideStalker()
		sendChat("You got lucky. This time.")
		showMessage("...", 2, 40)
	end

	task.wait(2)
	hideStalker()
	sounds.Breathing:Stop()
	TweenService:Create(sounds.Heartbeat, TweenInfo.new(1), {Volume = 0}):Play()
	task.wait(1)
	sounds.Heartbeat:Stop()

	behindYouActive = false
end

