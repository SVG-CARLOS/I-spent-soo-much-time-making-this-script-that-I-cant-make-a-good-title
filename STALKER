local function flashScreen(color, duration, intensity)
	color = color or Color3.new(0.5, 0, 0)
	duration = duration or 0.3
	intensity = intensity or 0.3
	redFlash.BackgroundColor3 = color
	TweenService:Create(redFlash, TweenInfo.new(0.05), {BackgroundTransparency = 1 - intensity}):Play()
	task.wait(duration)
	TweenService:Create(redFlash, TweenInfo.new(0.3), {BackgroundTransparency = 1}):Play()
end

local function staticBurst(duration, intensity)
	duration = duration or 0.5
	intensity = intensity or 0.3
	staticOverlay.ImageTransparency = 1 - intensity
	sounds.Static:Play()
	task.wait(duration)
	staticOverlay.ImageTransparency = 1
	sounds.Static:Stop()
end

local function subliminalFlash(duration)
	duration = duration or 0.08
	subliminalImage.BackgroundTransparency = 0
	subliminalImage.ImageTransparency = 0
	task.wait(duration)
	subliminalImage.BackgroundTransparency = 1
	subliminalImage.ImageTransparency = 1
end

local function distortCamera(intensity, duration)
	intensity = intensity or 5
	duration = duration or 0.5
	local originalFOV = Camera.FieldOfView
	local elapsed = 0
	while elapsed < duration do
		Camera.FieldOfView = originalFOV + math.sin(elapsed * 30) * intensity * (1 - elapsed / duration)
		local roll = math.sin(elapsed * 20) * math.rad(intensity) * (1 - elapsed / duration)
		Camera.CFrame = Camera.CFrame * CFrame.Angles(0, 0, roll)
		elapsed = elapsed + RunService.RenderStepped:Wait()
	end
	Camera.FieldOfView = originalFOV
end

local function shakeCamera(intensity, duration)
	intensity = intensity or 2
	duration = duration or 0.5
	local elapsed = 0
	while elapsed < duration do
		local offset = Vector3.new(
			(math.random() - 0.5) * intensity,
			(math.random() - 0.5) * intensity,
			(math.random() - 0.5) * intensity
		) * (1 - elapsed / duration)
		Camera.CFrame = Camera.CFrame * CFrame.new(offset)
		elapsed = elapsed + RunService.RenderStepped:Wait()
	end
end

local function getPositionBehind(targetRoot, distance)
	distance = distance or 8
	local lookVector = targetRoot.CFrame.LookVector
	return targetRoot.Position - lookVector * distance
end

local function isPlayerLookingAtStalker(targetRoot, stalkerPos)
	local toStalker = (stalkerPos - targetRoot.Position).Unit
	local lookDir = targetRoot.CFrame.LookVector
	local dot = lookDir:Dot(toStalker)
	return dot > 0.3
end

