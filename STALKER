local function createSound(name, id, volume, looped, pitch)
	local s = Instance.new("Sound")
	s.Name = name
	s.SoundId = "rbxassetid://" .. id
	s.Volume = volume or 1
	s.Looped = looped or false
	s.PlaybackSpeed = pitch or 1
	s.Parent = Camera
	sounds[name] = s
	return s
end

