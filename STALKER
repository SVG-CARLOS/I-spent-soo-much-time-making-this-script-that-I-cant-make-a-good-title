local function refreshDropdown()
	for _, child in pairs(dropdownList:GetChildren()) do
		if child:IsA("TextButton") then child:Destroy() end
	end

	local playerList = Players:GetPlayers()
	local count = 0
	for _, p in pairs(playerList) do
		if p ~= player then
			count = count + 1
			local btn = Instance.new("TextButton")
			btn.Size = UDim2.new(1, 0, 0, 28)
			btn.BackgroundColor3 = Color3.fromRGB(30, 3, 3)
			btn.BorderSizePixel = 0
			btn.Text = "  " .. p.Name
			btn.TextColor3 = Color3.fromRGB(200, 200, 200)
			btn.Font = Enum.Font.Code
			btn.TextSize = 13
			btn.TextXAlignment = Enum.TextXAlignment.Left
			btn.ZIndex = 51
			btn.Parent = dropdownList

			btn.MouseButton1Click:Connect(function()
				selectedTarget = p
				targetDropdown.Text = p.Name
				targetDropdown.TextColor3 = Color3.fromRGB(255, 60, 60)
				dropdownOpen = false
				dropdownList.Visible = false
				dropdownList.Size = UDim2.new(1, 0, 0, 0)
			end)

			btn.MouseEnter:Connect(function()
				btn.BackgroundColor3 = Color3.fromRGB(60, 5, 5)
			end)
			btn.MouseLeave:Connect(function()
				btn.BackgroundColor3 = Color3.fromRGB(30, 3, 3)
			end)
		end
	end

	if count == 0 then
		local noOne = Instance.new("TextButton")
		noOne.Size = UDim2.new(1, 0, 0, 28)
		noOne.BackgroundColor3 = Color3.fromRGB(30, 3, 3)
		noOne.BorderSizePixel = 0
		noOne.Text = "  No other players"
		noOne.TextColor3 = Color3.fromRGB(100, 100, 100)
		noOne.Font = Enum.Font.Code
		noOne.TextSize = 13
		noOne.ZIndex = 51
		noOne.Parent = dropdownList
	end

	dropdownList.Size = UDim2.new(1, 0, 0, math.min(count, 6) * 28)
end

targetDropdown.MouseButton1Click:Connect(function()
	dropdownOpen = not dropdownOpen
	if dropdownOpen then
		refreshDropdown()
		dropdownList.Visible = true
	else
		dropdownList.Visible = false
	end
end)

