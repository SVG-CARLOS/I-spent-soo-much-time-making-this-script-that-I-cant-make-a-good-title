local function updateStalkerPose(position, lookAt)
	local cf = CFrame.new(position, Vector3.new(lookAt.X, position.Y, lookAt.Z))
	stalkerTorso.CFrame = cf
	stalkerHead.CFrame = cf * CFrame.new(0, 3.8, 0)
	leftEye.CFrame = cf * CFrame.new(-0.35, 3.9, -0.8)
	rightEye.CFrame = cf * CFrame.new(0.35, 3.9, -0.8)
	leftArm.CFrame = cf * CFrame.new(-1.5, 1.2, 0) * CFrame.Angles(math.rad(-15 + math.sin(tick() * 2) * 5), 0, math.rad(-10))
	rightArm.CFrame = cf * CFrame.new(1.5, 1.2, 0) * CFrame.Angles(math.rad(-15 + math.sin(tick() * 2 + 1) * 5), 0, math.rad(10))
	leftLeg.CFrame = cf * CFrame.new(-0.5, -2.8, 0) * CFrame.Angles(math.sin(tick() * 4) * 0.2, 0, 0)
	rightLeg.CFrame = cf * CFrame.new(0.5, -2.8, 0) * CFrame.Angles(math.sin(tick() * 4 + math.pi) * 0.2, 0, 0)
end

local function hideStalker()
	for _, part in pairs(stalkerModel:GetChildren()) do
		if part:IsA("BasePart") then
			part.Transparency = 1
			for _, child in pairs(part:GetChildren()) do
				if child:IsA("PointLight") then child.Enabled = false end
				if child:IsA("ParticleEmitter") then child.Enabled = false end
			end
		end
	end
end

local function showStalker(transparency)
	transparency = transparency or 0
	for _, part in pairs(stalkerModel:GetChildren()) do
		if part:IsA("BasePart") then
			if part.Name == "LeftEye" or part.Name == "RightEye" then
				part.Transparency = 0
			else
				part.Transparency = transparency
			end
			for _, child in pairs(part:GetChildren()) do
				if child:IsA("PointLight") then child.Enabled = true end
				if child:IsA("ParticleEmitter") then child.Enabled = true end
			end
		end
	end
end

hideStalker()

