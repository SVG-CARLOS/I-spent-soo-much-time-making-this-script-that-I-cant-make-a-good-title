	for i = 1, 30 do
		local t = i / 30
		sounds.Heartbeat.Volume = 0.2 + t * 1.3
		sounds.Heartbeat.PlaybackSpeed = 0.6 + t * 1.8

		vignetteFrame.BackgroundTransparency = 0.6 - t * 0.4

		if t > 0.5 then
			local pulseIntensity = t * 0.3
			redFlash.BackgroundTransparency = 1 - pulseIntensity * math.abs(math.sin(tick() * sounds.Heartbeat.PlaybackSpeed * 3))
		end

		if t > 0.7 then
			shakeCamera(t * 3, 0.1)
		end

		if t > 0.9 then
			staticBurst(0.05, t * 0.5)
		end

		task.wait(0.3 - t * 0.2)
	end

	sounds.Jumpscare:Play()
	blackScreen.BackgroundTransparency = 0
	flashScreen(Color3.new(1, 0, 0), 0.5, 1)
	shakeCamera(10, 0.5)

	task.wait(1)
	TweenService:Create(blackScreen, TweenInfo.new(2), {BackgroundTransparency = 1}):Play()
	TweenService:Create(vignetteFrame, TweenInfo.new(1), {BackgroundTransparency = 1}):Play()
	redFlash.BackgroundTransparency = 1
	sounds.Heartbeat:Stop()
end

-- ═══════════════════════════════════════════════════════
-- FEATURE: POSSESSION
-- ═══════════════════════════════════════════════════════

local function possession()
	sendChat("I'm taking over.")

	task.wait(1.5)

	local cc = Instance.new("ColorCorrectionEffect")
	cc.Saturation = -0.8
	cc.Contrast = 0.3
	cc.TintColor = Color3.fromRGB(255, 150, 150)
	cc.Parent = Lighting

	local blur = Instance.new("BlurEffect")
	blur.Size = 0
	blur.Parent = Lighting

	sounds.Distortion:Play()

	for i = 1, 40 do
		local t = i / 40
		blur.Size = t * 15
		cc.Saturation = -0.8 - t * 0.2
		cc.Contrast = 0.3 + t * 0.3

		Camera.FieldOfView = 70 + math.sin(i * 0.3) * t * 15

		if math.random() < 0.1 then
			staticBurst(0.05, 0.3)
		end

		if math.random() < 0.05 then
			local glitchMsgs = {"MINE", "SUBMIT", "OBEY", "GIVE IN"}
			showMessage(glitchMsgs[math.random(#glitchMsgs)], 0.3, 40)
		end

		task.wait(0.1)
	end

	sendChat("You belong to me now.")

	task.wait(2)

	for i = 40, 0, -1 do
		local t = i / 40
		blur.Size = t * 15
		cc.Saturation = -0.8 - t * 0.2
		task.wait(0.05)
	end

	Camera.FieldOfView = 70
	blur:Destroy()
	cc:Destroy()
	sounds.Distortion:Stop()
end

